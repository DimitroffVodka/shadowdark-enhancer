# Local development
*.log

# Local working data — never committed. Nothing under data/ has ever been
# tracked, and two things in here must not be:
#   monster-art-mapping.json  generated + install-specific (references the
#     user's own locally-installed art module; regenerated by the Monster Art
#     tool).
#   bestiary-reference.json   a third-party scrape whose entries carry verbatim
#     statblock text. This repo publishes only names, source/page citations,
#     formulas, and parsing structure — no rules text — so it stays local.
data/

# Claude Code per-project state (session/cache — never commit)
.claude/

# Playwright MCP scratch output
.playwright-mcp/
