<div class="sde-forge">

  {{!-- Type selector --}}
  <div class="sde-forge-types">
    {{#each types as |t|}}
      <button type="button" class="sde-forge-type {{#if t.active}}active{{/if}}"
        data-action="setType" data-type="{{t.id}}">
        <i class="fas {{t.icon}}"></i> {{t.label}}
      </button>
    {{/each}}
  </div>

  {{!-- Manual / Core mode toggle (weapon & armor only) --}}
  {{#if coreAvailable}}
    <div class="sde-forge-modes">
      <button type="button" class="sde-forge-mode {{#unless isCore}}active{{/unless}}"
        data-action="setMode" data-mode="manual"><i class="fas fa-hand"></i> Manual</button>
      <button type="button" class="sde-forge-mode {{#if isCore}}active{{/if}}"
        data-action="setMode" data-mode="core"><i class="fas fa-book"></i> Core Rulebook tables</button>
    </div>
  {{/if}}

  <div class="sde-forge-cols">

    {{!-- ── Left: controls ── --}}
    <div class="sde-forge-build">

      {{#if isGear}}
        {{#unless isCore}}
        <div class="sde-forge-field">
          <label class="sde-forge-label">Magic Bonus</label>
          <div class="sde-forge-bonus-row">
            {{#each bonusOptions as |b|}}
              <button type="button" class="sde-forge-bonus {{#if b.active}}active{{/if}}"
                data-action="setBonus" data-bonus="{{b.n}}">+{{b.n}}</button>
            {{/each}}
          </div>
        </div>
        {{/unless}}

        <div class="sde-forge-field">
          <label class="sde-forge-label">Base {{typeLabel}}
            {{#if typeHint}}<span class="sde-forge-hint">Core type hint: {{typeHint}}</span>{{/if}}
          </label>
          {{#if baseSelected}}
            <div class="sde-forge-base-selected">
              <img src="{{baseSelected.img}}" alt="" width="22" height="22">
              <span>{{baseSelected.name}}</span>
              <button type="button" class="sde-forge-x" data-action="clearBase" title="Change base">
                <i class="fas fa-xmark"></i>
              </button>
            </div>
          {{else}}
            <input type="text" class="sde-forge-base-search" placeholder="Search base {{typeLabel}}…">
            <div class="sde-forge-list">
              {{#each bases as |b|}}
                <div class="sde-forge-row sde-forge-base-row" data-action="pickBase"
                  data-uuid="{{b.uuid}}" data-name="{{b.nameLower}}">
                  <img src="{{b.img}}" alt="" width="22" height="22">
                  <span class="sde-forge-row-name">{{b.name}}</span>
                </div>
              {{/each}}
            </div>
          {{/if}}
        </div>

        {{!-- Core Rulebook table panel (imported tables only) --}}
        {{#if isCore}}
          <div class="sde-forge-core">
            {{#each coreSets as |set|}}
              <div class="sde-forge-core-set state-{{set.badge.cls}}">
                <div class="sde-forge-core-set-head">
                  <span class="sde-forge-badge {{set.badge.cls}}"><i class="fas {{set.badge.icon}}"></i> {{set.badge.label}}</span>
                  <span class="sde-forge-core-set-name">{{set.label}}</span>
                  <span class="sde-forge-core-set-page">{{set.pageLabel}}</span>
                </div>
                {{#unless set.ready}}
                  {{#each set.diagnostics as |d|}}<div class="sde-forge-core-diag">{{d.message}}</div>{{/each}}
                  {{#unless set.perTable}}
                    <button type="button" class="sde-forge-core-import" data-action="coreImport" data-set="{{set.key}}">
                      <i class="fas fa-file-import"></i> Import “{{set.label}}” from Core Rulebook…
                    </button>
                  {{/unless}}
                {{/unless}}
                {{#each set.fields as |f|}}
                  <div class="sde-forge-core-field role-{{f.roleClass}}">
                    <div class="sde-forge-core-field-head">
                      <span class="sde-forge-core-field-name">{{f.label}}</span>
                      <span class="sde-forge-core-role {{f.roleClass}}">{{f.roleLabel}}</span>
                    </div>
                    {{#if f.ready}}
                      <div class="sde-forge-core-controls">
                        <select class="sde-forge-core-select" data-manifest-id="{{f.manifestId}}">
                          <option value="">— choose —</option>
                          {{#each f.results as |r|}}
                            <option value="{{r.resultId}}" {{#if r.selected}}selected{{/if}}>{{r.rangeLabel}}. {{r.text}}</option>
                          {{/each}}
                        </select>
                        <button type="button" class="sde-forge-core-btn" data-action="coreRoll" data-manifest-id="{{f.manifestId}}" title="Roll on this table"><i class="fas fa-dice-d20"></i></button>
                        {{#if f.hasSelection}}<button type="button" class="sde-forge-core-btn" data-action="coreClear" data-manifest-id="{{f.manifestId}}" title="Clear selection"><i class="fas fa-xmark"></i></button>{{/if}}
                      </div>
                      {{#if f.hasSelection}}<div class="sde-forge-core-picked">{{f.selectedText}}</div>{{/if}}
                    {{else}}
                      {{#if f.perTable}}
                        <button type="button" class="sde-forge-core-import small" data-action="coreImport" data-child="{{f.manifestId}}">
                          <i class="fas fa-file-import"></i> Import “{{f.label}}”…
                        </button>
                      {{else}}
                        <span class="sde-forge-core-muted">not imported</span>
                      {{/if}}
                    {{/if}}
                  </div>
                {{/each}}
              </div>
            {{/each}}
          </div>
        {{/if}}
      {{/if}}

      {{#if isSpellItem}}
        <div class="sde-forge-field">
          <label class="sde-forge-label">
            Spell{{#if isWand}}s{{/if}}
            <span class="sde-forge-hint">{{#if isWand}}pick one or more{{else}}pick one{{/if}}</span>
          </label>
          <input type="text" class="sde-forge-spell-search" placeholder="Search spells…">
          <div class="sde-forge-tier-row">
            <span class="sde-forge-tier-label">Tier</span>
            {{#each tierChips as |tc|}}
              <button type="button" class="sde-forge-tier {{#if tc.active}}active{{/if}}"
                data-action="setTier" data-tier="{{tc.tier}}">{{tc.label}}</button>
            {{/each}}
          </div>
          <div class="sde-forge-spell-classes">
            {{#each spellGroups as |g|}}
              <details class="sde-forge-spell-group" data-class="{{g.className}}" {{#if g.open}}open{{/if}}>
                <summary class="sde-forge-spell-group-head">
                  <i class="fas fa-chevron-right sde-forge-group-caret"></i>
                  <span class="sde-forge-group-name">{{g.className}}</span>
                  <span class="sde-forge-group-count">{{g.count}}</span>
                </summary>
                <div class="sde-forge-list sde-forge-spell-list">
                  {{#each g.spells as |s|}}
                    <div class="sde-forge-row sde-forge-spell-row {{#if s.selected}}selected{{/if}}"
                      data-action="toggleSpell" data-uuid="{{s.uuid}}" data-name="{{s.nameLower}}" data-tier="{{s.tier}}">
                      <img src="{{s.img}}" alt="" width="22" height="22">
                      <span class="sde-forge-row-name">{{s.name}}</span>
                      <span class="sde-forge-row-meta">T{{s.tier}} · DC {{s.dc}}</span>
                      <button type="button" class="sde-forge-spell-peek" data-action="openSpell"
                        data-uuid="{{s.uuid}}" title="Open spell to review">
                        <i class="fas fa-up-right-from-square"></i>
                      </button>
                      <i class="fas fa-check sde-forge-row-check"></i>
                    </div>
                  {{/each}}
                </div>
              </details>
            {{/each}}
          </div>
        </div>
      {{/if}}

      <div class="sde-forge-field">
        <label class="sde-forge-label" for="sde-forge-name">Name <span class="sde-forge-hint">optional override</span></label>
        <input type="text" name="name" id="sde-forge-name" value="{{name}}" placeholder="(auto)" class="sde-forge-input">
      </div>

      <label class="sde-forge-check">
        <input type="checkbox" name="identified" {{#if identified}}checked{{/if}}>
        Identified (uncheck to start unidentified)
      </label>
    </div>

    {{!-- ── Right: live preview ── --}}
    <div class="sde-forge-preview">
      <div class="sde-forge-preview-badge"><i class="fas {{preview.icon}}"></i> {{preview.typeLabel}}</div>
      <div class="sde-forge-preview-name">{{preview.name}}</div>
      <ul class="sde-forge-preview-lines">
        {{#each preview.lines as |line|}}<li>{{line}}</li>{{/each}}
      </ul>
      <button type="button" class="sde-forge-create" data-action="createItem" {{#unless canForge}}disabled{{/unless}}>
        <i class="fas fa-hammer"></i> Forge Item
      </button>
    </div>

  </div>
</div>
