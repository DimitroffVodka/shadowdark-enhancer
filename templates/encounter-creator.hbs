<div class="sde-creator">

  {{#if _loaderOpen}}

    {{!-- ═══ Bestiary Loader Takeover (1e-v) ═══════════════════════════
         When active, this view REPLACES the entire creator UI. It mirrors
         the Browse NPCs tab — same filter sidebar + sortable table — but
         clicking a row PICKS the NPC into the draft and returns to the
         creator. Filters run through the same EncounterBrowse pipeline,
         so behavior matches Browse exactly (loader-local source selection
         that doesn't write back to the Browse tab's setting). --}}
    <div class="sde-creator-loader-takeover">

      <header class="sde-creator-loader-bar">
        <button type="button" class="sde-creator-loader-cancel" data-action="creatorToggleLoader" title="Back to Creator">
          <i class="fas fa-arrow-left"></i> Back
        </button>
        <span class="sde-creator-loader-title"><i class="fas fa-book"></i> Load From Bestiary</span>
        <span class="sde-creator-loader-count">{{loaderData.filteredCount}} of {{loaderData.totalCount}}</span>
      </header>

      <div class="sde-browse-v2 sde-creator-loader-browse">

        {{!-- ═══ Left Sidebar: Filters ═══ --}}
        <aside class="sde-browse-sidebar">
          <h3 class="sde-browse-sidebar-title">Filters</h3>

          {{!-- Sources --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-filter-label">Sources</label>
            <details class="sde-browse-dropdown">
              <summary>{{loaderData.sourcesLabel}}</summary>
              <div class="sde-browse-dropdown-menu">
                {{#each loaderData.availableSources}}
                  <label class="sde-browse-check">
                    <input type="checkbox"
                           {{#if (includes ../loaderData.selectedSources this.id)}}checked{{/if}}
                           data-action="creatorLoaderToggleSource"
                           data-source-id="{{this.id}}">
                    <span>{{this.label}}</span>
                  </label>
                {{/each}}
              </div>
            </details>
          </div>

          {{!-- Search — writes this._loaderSearch via data-loader-search
               (not data-draft-field); see _wireLoaderInputs. --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-filter-label" for="sde-ldr-search">Search</label>
            <input id="sde-ldr-search"
                   type="text"
                   data-loader-search
                   class="sde-browse-search"
                   placeholder="Search bestiary…"
                   value="{{loaderData.search}}">
          </div>

          {{!-- Alignment --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-filter-label">Alignment</label>
            <div class="sde-browse-align-group">
              {{#each (array "L" "N" "C")}}
                <button type="button"
                        class="sde-browse-align-pill {{#if (includes ../loaderData.alignment this)}}is-active{{/if}}"
                        data-action="creatorLoaderToggleAlign"
                        aria-pressed="{{#if (includes ../loaderData.alignment this)}}true{{else}}false{{/if}}"
                        data-alignment="{{this}}">{{this}}</button>
              {{/each}}
            </div>
          </div>

          {{!-- Level range --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-filter-label">Level</label>
            <div class="sde-browse-level-group">
              <input type="number" name="loaderLevelMin" class="sde-browse-level-input" placeholder="min" aria-label="Minimum level" value="{{#unless (eq loaderData.levelMin null)}}{{loaderData.levelMin}}{{/unless}}">
              <span class="sde-browse-level-sep">–</span>
              <input type="number" name="loaderLevelMax" class="sde-browse-level-input" placeholder="max" aria-label="Maximum level" value="{{#unless (eq loaderData.levelMax null)}}{{loaderData.levelMax}}{{/unless}}">
            </div>
          </div>

          <div class="sde-browse-filter-pair">
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label">HP</label>
              <div class="sde-browse-level-group">
                <input type="number" name="loaderHpMin" class="sde-browse-level-input" placeholder="min" aria-label="Minimum HP" value="{{#unless (eq loaderData.hpMin null)}}{{loaderData.hpMin}}{{/unless}}">
                <span class="sde-browse-level-sep">–</span>
                <input type="number" name="loaderHpMax" class="sde-browse-level-input" placeholder="max" aria-label="Maximum HP" value="{{#unless (eq loaderData.hpMax null)}}{{loaderData.hpMax}}{{/unless}}">
              </div>
            </div>
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label">AC</label>
              <div class="sde-browse-level-group">
                <input type="number" name="loaderAcMin" class="sde-browse-level-input" placeholder="min" aria-label="Minimum AC" value="{{#unless (eq loaderData.acMin null)}}{{loaderData.acMin}}{{/unless}}">
                <span class="sde-browse-level-sep">–</span>
                <input type="number" name="loaderAcMax" class="sde-browse-level-input" placeholder="max" aria-label="Maximum AC" value="{{#unless (eq loaderData.acMax null)}}{{loaderData.acMax}}{{/unless}}">
              </div>
            </div>
          </div>

          {{!-- Movement --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-filter-label" for="sde-ldr-move">Movement</label>
            <select id="sde-ldr-move" name="loaderMove" class="sde-browse-select">
              <option value="" {{#unless loaderData.moves.length}}selected{{/unless}}>All movement</option>
              {{#each loaderData.moveOptions}}
                <option value="{{this}}" {{#if (includes ../loaderData.moves this)}}selected{{/if}}>{{this}}</option>
              {{/each}}
            </select>
          </div>

          {{!-- Boolean toggles --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-check">
              <input type="checkbox"
                     {{#if loaderData.darkAdapted}}checked{{/if}}
                     data-action="creatorLoaderToggleDark">
              <span>Dark-Adapted</span>
            </label>
            <label class="sde-browse-check">
              <input type="checkbox"
                     {{#if loaderData.hasSpellcasting}}checked{{/if}}
                     data-action="creatorLoaderToggleSpellcaster">
              <span>Spellcaster</span>
            </label>
          </div>

          {{!-- Abilities (text-search NPC Feature names) --}}
          <div class="sde-browse-filter">
            <label class="sde-browse-filter-label" for="sde-ldr-ability">Abilities</label>
            <input id="sde-ldr-ability"
                   type="text"
                   data-loader-ability
                   class="sde-browse-search"
                   placeholder="e.g. petrify, magic resistance"
                   value="{{loaderData.abilitySearch}}">
          </div>
        </aside>

        {{!-- ═══ Right pane: Results table ═══ --}}
        <div class="sde-browse-results sde-scrollbar">
          {{#if loaderData.noSources}}
            <div class="sde-empty-state">No sources selected. Enable one or more sources above to load NPCs.</div>
          {{else if loaderData.empty}}
            <div class="sde-empty-state">No matching NPCs. Try widening the filters or enabling more sources.</div>
          {{else}}
            <table class="sde-browse-table sde-creator-loader-table">
              <thead>
                <tr>
                  <th></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "name")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="name">Name {{#if (eq loaderData.sortCol "name")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "level")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="level">LV {{#if (eq loaderData.sortCol "level")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "alignment")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="alignment">Al {{#if (eq loaderData.sortCol "alignment")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "hp")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="hp">HP {{#if (eq loaderData.sortCol "hp")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "ac")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="ac">AC {{#if (eq loaderData.sortCol "ac")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "dpr")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="dpr">DPR {{#if (eq loaderData.sortCol "dpr")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  <th aria-sort="{{#if (eq loaderData.sortCol "attackCount")}}{{#if loaderData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="creatorLoaderSort" data-column="attackCount">Attack {{#if (eq loaderData.sortCol "attackCount")}}{{#if loaderData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                </tr>
              </thead>
              <tbody>
                {{#each loaderData.rows}}
                  <tr class="sde-browse-row sde-creator-loader-row" data-action="creatorLoaderPick" data-uuid="{{this.uuid}}" title="Click to load {{this.name}}">
                    <td><img src="{{this.img}}" width="24" height="24" alt="" loading="lazy" decoding="async" /></td>
                    <td class="sde-browse-name" title="{{this.name}}">{{this.name}}</td>
                    <td>{{this.levelLabel}}</td>
                    <td title="{{this.alignmentLabel}}">{{#if this.alignment}}{{this.alignment}}{{else}}—{{/if}}</td>
                    <td title="HP">{{this.hpLabel}}</td>
                    <td>{{this.acLabel}}</td>
                    <td>{{this.dprLabel}}</td>
                    <td class="sde-browse-atk-cell">
                      {{#if this.attackCount}}
                        <span class="sde-browse-atk-count" title="{{this.primaryAttack}}">{{this.attackSummary}}</span>
                        {{#if this.attackKinds.melee}}<i class="fas fa-swords sde-browse-atk-melee" title="Melee"></i>{{/if}}
                        {{#if this.attackKinds.ranged}}<i class="fas fa-crosshairs sde-browse-atk-ranged" title="Ranged"></i>{{/if}}
                        {{#if this.attackKinds.special}}<i class="fas fa-bolt sde-browse-atk-special" title="Special attack"></i>{{/if}}
                      {{else}}
                        <span class="sde-browse-atk-none">—</span>
                      {{/if}}
                      {{#if this.hasSpellcasting}}<i class="fas fa-wand-sparkles sde-browse-atk-spell" title="Spellcaster (+{{this.spellcastingBonus}})"></i>{{/if}}
                      {{#if this.darkAdapted}}<i class="fas fa-moon sde-browse-atk-dark" title="Dark-Adapted"></i>{{/if}}
                    </td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          {{/if}}
        </div>

      </div>
    </div>

  {{else}}

    {{!-- ═══ Bestiary Loader Trigger (only shown when NOT in loader) ═══ --}}
    <div class="sde-creator-loader-wrapper">
      <button type="button" class="sde-creator-loader-btn" data-action="creatorToggleLoader">
        <i class="fas fa-book"></i> Load From Bestiary&hellip;
      </button>
    </div>

    {{!-- ═══ Identity Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.identity}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="identity">
      <i class="fas fa-id-card"></i> Identity
    </summary>
    <div class="sde-creator-section-body">

      <div class="sde-creator-row">
        <label for="sde-cr-name">Name</label>
        <input id="sde-cr-name" type="text" data-draft-field="name" value="{{draft.name}}" placeholder="e.g. Frost Goblin">
      </div>

      <div class="sde-creator-row">
        <label>Alignment</label>
        <div class="sde-creator-align-group">
          {{#each alignments}}
            <label class="sde-creator-radio-label">
              <input type="radio" name="alignment" value="{{this}}"
                     {{#if (eq this ../draft.alignment)}}checked{{/if}}
                     data-draft-field="alignment">
              {{this}}
            </label>
          {{/each}}
        </div>
      </div>

      <div class="sde-creator-row">
        <label for="sde-cr-level">Level</label>
        <input id="sde-cr-level" type="number" data-draft-field="level" value="{{draft.level}}" min="0" max="30">
      </div>

      <div class="sde-creator-row">
        <label for="sde-cr-img">Portrait</label>
        <div class="sde-creator-img-picker">
          <img src="{{draft.img}}" width="48" height="48" alt="" />
          <input id="sde-cr-img" type="text" data-draft-field="img" value="{{draft.img}}" class="sde-creator-img-path">
          <button type="button" data-action="pickImg" title="Browse"><i class="fas fa-folder-open"></i></button>
        </div>
      </div>

      <div class="sde-creator-row">
        <label for="sde-cr-token">Token image</label>
        <div class="sde-creator-img-picker">
          <img src="{{#if draft.tokenSrc}}{{draft.tokenSrc}}{{else}}{{draft.img}}{{/if}}" width="48" height="48" alt="" />
          <input id="sde-cr-token" type="text" data-draft-field="tokenSrc" value="{{draft.tokenSrc}}" placeholder="(inherits from portrait)" class="sde-creator-img-path">
          <button type="button" data-action="pickTokenSrc" title="Browse"><i class="fas fa-folder-open"></i></button>
        </div>
      </div>

    </div>
  </details>

  {{!-- ═══ Stats Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.stats}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="stats">
      <i class="fas fa-heart-pulse"></i> Stats
    </summary>
    <div class="sde-creator-section-body">

      <div class="sde-creator-row">
        <label for="sde-cr-hp-value">HP</label>
        <div class="sde-creator-hp-pair">
          <input id="sde-cr-hp-value" type="number" data-draft-field="hp.value" value="{{draft.hp.value}}" min="0" title="Current HP" aria-label="Current HP">
          <span>/</span>
          <input type="number" data-draft-field="hp.max" value="{{draft.hp.max}}" min="1" title="Maximum HP" aria-label="Maximum HP">
        </div>
      </div>

      <div class="sde-creator-row">
        <label for="sde-cr-ac">AC</label>
        <input id="sde-cr-ac" type="number" data-draft-field="ac" value="{{draft.ac}}" min="0">
      </div>

      <div class="sde-creator-row">
        <label>Abilities</label>
        <div class="sde-creator-ability-grid">
          {{#each (array "str" "dex" "con" "int" "wis" "cha")}}
            <div class="sde-creator-ability">
              <span class="sde-creator-ability-label" aria-hidden="true">{{this}}</span>
              <input type="number" data-draft-field="abilities.{{this}}"
                     value="{{lookup ../draft.abilities this}}"
                     aria-label="{{this}} ability score"
                     placeholder="0">
            </div>
          {{/each}}
        </div>
      </div>

      <div class="sde-creator-row">
        <label for="sde-cr-dark">Dark-Adapted</label>
        <input id="sde-cr-dark" type="checkbox" data-draft-field="darkAdapted" {{#if draft.darkAdapted}}checked{{/if}}>
      </div>

    </div>
  </details>

  {{!-- ═══ Movement Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.movement}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="movement">
      <i class="fas fa-shoe-prints"></i> Movement
    </summary>
    <div class="sde-creator-section-body">
      <div class="sde-creator-row">
        <label for="sde-cr-move">Type</label>
        <select id="sde-cr-move" data-draft-field="move">
          {{#each moveOptions}}
            <option value="{{this}}" {{#if (eq this ../draft.move)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="sde-creator-row">
        <label for="sde-cr-movenote">Note</label>
        <input id="sde-cr-movenote" type="text" data-draft-field="moveNote" value="{{draft.moveNote}}" placeholder="e.g. climb, fly 60'">
      </div>
    </div>
  </details>

  {{!-- ═══ Actions Section (1e-iii) ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.actions}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="actions">
      <i class="fas fa-swords"></i> Actions
    </summary>
    <div class="sde-creator-section-body">

      {{!-- Quick Picks — iterate the catalog directly so additions /
           removals to ACTION_QUICK_PICKS don't require a template edit. --}}
      <div class="sde-creator-quick-picks">
        <label>Quick Add:</label>
        <div class="sde-creator-quick-grid">
          {{#each ACTION_QUICK_PICKS}}
            <button type="button" class="sde-creator-quick-btn"
                    data-action="creatorAddQuickPick" data-index="{{@index}}"
                    title="{{name}}{{#if (eq type 'NPC Attack')}} — {{num}}× +{{bonus}} {{damage}}{{/if}}{{#if description}} — {{description}}{{/if}}">
              <i class="fas {{icon}}"></i>
              <span class="sde-creator-quick-name">{{name}}</span>
            </button>
          {{/each}}
        </div>
      </div>

      {{!-- Action List --}}
      <div class="sde-creator-action-list">
        {{#each draft.actions}}
          <div class="sde-creator-action-card" data-id="{{id}}">
            <div class="sde-creator-action-header">
              <input type="text" data-draft-field="actions.{{@index}}.name" value="{{name}}" placeholder="Action Name">
              <button type="button" class="sde-creator-remove-btn" data-action="creatorRemoveAction" data-id="{{id}}">
                <i class="fas fa-trash"></i>
              </button>
            </div>

            {{#if (eq type "NPC Attack")}}
              <div class="sde-creator-action-grid">
                <div class="sde-creator-row-mini">
                  <label>Count</label>
                  <input type="number" data-draft-field="actions.{{@index}}.num" value="{{num}}" min="1" aria-label="Attack count">
                </div>
                <div class="sde-creator-row-mini">
                  <label>Atk</label>
                  <input type="number" data-draft-field="actions.{{@index}}.bonus" value="{{bonus}}" aria-label="Attack bonus">
                </div>
                <div class="sde-creator-row-mini">
                  <label>Damage</label>
                  <input type="text" data-draft-field="actions.{{@index}}.damage" value="{{damage}}" placeholder="1d6" aria-label="Damage">
                </div>
              </div>
              {{!-- Range pills — iterate `ranges` (close/near/far/nearLine
                   from CONFIG.SHADOWDARK.RANGES), NOT the movement enum.
                   The array-checkbox handler in _wireFieldInputs toggles
                   the string value in/out of the slot's ranges array. --}}
              <div class="sde-creator-ranges">
                {{#each @root.ranges}}
                  <label class="sde-creator-range-pill {{#if (includes ../ranges this)}}active{{/if}}">
                    <input type="checkbox" data-draft-field="actions.{{@../index}}.ranges"
                           value="{{this}}" {{#if (includes ../ranges this)}}checked{{/if}} class="hidden">
                    {{this}}
                  </label>
                {{/each}}
              </div>
            {{/if}}

            <textarea data-draft-field="actions.{{@index}}.description" rows="2"
                      placeholder="Special effects, status conditions, or flavor text.">{{description}}</textarea>
          </div>
        {{else}}
          <div class="sde-creator-empty">No actions added yet.</div>
        {{/each}}
      </div>

      <div class="sde-creator-action-buttons">
        <button type="button" data-action="creatorAddAction"><i class="fas fa-plus"></i> Attack</button>
        <button type="button" data-action="creatorAddSpecial"><i class="fas fa-plus"></i> Special</button>
      </div>

    </div>
  </details>

  {{!-- ═══ Features Section (1e-iv) ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.features}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="features">
      <i class="fas fa-star"></i> Features
    </summary>
    <div class="sde-creator-section-body">

      {{!-- Quick Picks --}}
      <div class="sde-creator-quick-picks">
        <label>Quick Add:</label>
        <div class="sde-creator-quick-grid">
          {{#each FEATURE_QUICK_PICKS}}
            <button type="button" class="sde-creator-quick-btn"
                    data-action="creatorAddFeatureQuickPick" data-index="{{@index}}"
                    title="{{name}}: {{description}}">
              <i class="fas {{icon}}"></i>
            </button>
          {{/each}}
        </div>
      </div>

      {{!-- Feature List --}}
      <div class="sde-creator-action-list">
        {{#each draft.features}}
          <div class="sde-creator-action-card" data-id="{{id}}">
            <div class="sde-creator-action-header">
              <input type="text" data-draft-field="features.{{@index}}.name" value="{{name}}" placeholder="Feature Name">
              <button type="button" class="sde-creator-remove-btn" data-action="creatorRemoveFeature" data-id="{{id}}">
                <i class="fas fa-trash"></i>
              </button>
            </div>
            <textarea data-draft-field="features.{{@index}}.description" rows="2"
                      placeholder="Description of the feature effect.">{{description}}</textarea>
          </div>
        {{else}}
          <div class="sde-creator-empty">No features added yet.</div>
        {{/each}}
      </div>

      <div class="sde-creator-action-buttons">
        <button type="button" data-action="creatorAddFeature"><i class="fas fa-plus"></i> Custom Feature</button>
      </div>

    </div>
  </details>

  {{!-- ═══ Mutations Section ═══
       Curated Shadowdark-native adaptation of Vagabond Crawler's mutation
       system. Cards toggle into a selection; "Apply to Draft" mutates the
       in-progress draft in place, "Create Mutated Copy" spins off a NEW
       world actor from a clone (draft untouched). Both run the same
       applyMutations engine (mutation-data.mjs). --}}
  <details class="sde-creator-section" {{#if sectionOpen.mutations}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="mutations">
      <i class="fas fa-dna"></i> Mutations
      {{#if mutations.selectedCount}}<span class="sde-mut-badge">{{mutations.selectedCount}}</span>{{/if}}
    </summary>
    <div class="sde-creator-section-body">

      {{!-- Category filter pills --}}
      <div class="sde-mut-categories">
        {{#each mutations.categories}}
          <button type="button" class="sde-mut-cat-pill {{#if this.active}}is-active{{/if}}"
                  data-action="creatorMutCategory" data-category="{{this.key}}"
                  aria-pressed="{{#if this.active}}true{{else}}false{{/if}}">
            <i class="fas {{this.icon}}"></i> {{this.label}}
          </button>
        {{/each}}
      </div>

      {{!-- Mutation cards --}}
      <div class="sde-mut-grid">
        {{#each mutations.list}}
          <button type="button"
                  class="sde-mut-card sde-mut-{{this.type}}{{#if this.selected}} is-selected{{/if}}{{#if this.conflict}} is-conflict{{/if}}"
                  data-action="creatorMutToggle" data-mutation-id="{{this.id}}"
                  aria-pressed="{{#if this.selected}}true{{else}}false{{/if}}"
                  title="{{this.description}}">
            <span class="sde-mut-card-head">
              <span class="sde-mut-name">{{this.name}}</span>
              {{#if this.selected}}<i class="fas fa-check sde-mut-check"></i>{{/if}}
            </span>
            <span class="sde-mut-desc">{{this.description}}</span>
            {{#if this.conflict}}
              <span class="sde-mut-conflict-note">Replaces {{this.conflict}}</span>
            {{else if this.suggestedBaneName}}
              <span class="sde-mut-suggest">Suggested bane: {{this.suggestedBaneName}}</span>
            {{/if}}
          </button>
        {{else}}
          <div class="sde-creator-empty">No mutations in this category.</div>
        {{/each}}
      </div>

      {{!-- Name preview (only when something is selected) --}}
      {{#if mutations.selectedCount}}
        <div class="sde-mut-preview">
          <span class="sde-mut-preview-label">Mutated name</span>
          <span class="sde-mut-preview-name">{{mutations.namePreview}}</span>
        </div>
      {{/if}}

      {{!-- Mutation actions --}}
      <div class="sde-creator-action-buttons sde-mut-actions">
        <button type="button" data-action="creatorMutApply" {{#unless mutations.selectedCount}}disabled{{/unless}}>
          <i class="fas fa-wand-magic-sparkles"></i> Apply to Draft
        </button>
        <button type="button" data-action="creatorMutCreateCopy" {{#unless mutations.selectedCount}}disabled{{/unless}}>
          <i class="fas fa-clone"></i> Create Mutated Copy
        </button>
        <button type="button" class="sde-mut-clear" data-action="creatorMutClear" {{#unless mutations.selectedCount}}disabled{{/unless}}>
          <i class="fas fa-xmark"></i> Clear
        </button>
      </div>

    </div>
  </details>

  {{!-- ═══ Spellcasting Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.spellcasting}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="spellcasting">
      <i class="fas fa-wand-sparkles"></i> Spellcasting
    </summary>
    <div class="sde-creator-section-body">
      <div class="sde-creator-row">
        <label for="sde-cr-sc-ability">Ability</label>
        <select id="sde-cr-sc-ability" data-draft-field="spellcasting.ability">
          <option value="" {{#unless draft.spellcasting.ability}}selected{{/unless}}>— None —</option>
          {{#each spellAbilities}}
            <option value="{{this}}" {{#if (eq this ../draft.spellcasting.ability)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="sde-creator-row">
        <label for="sde-cr-sc-bonus">Atk Bonus</label>
        <input id="sde-cr-sc-bonus" type="number" data-draft-field="spellcasting.bonus" value="{{draft.spellcasting.bonus}}" {{#unless draft.spellcasting.ability}}disabled{{/unless}}>
      </div>
      <div class="sde-creator-row">
        <label for="sde-cr-sc-attacks">Attacks/round</label>
        <input id="sde-cr-sc-attacks" type="number" data-draft-field="spellcasting.attacks" value="{{draft.spellcasting.attacks}}" min="0" {{#unless draft.spellcasting.ability}}disabled{{/unless}}>
      </div>

      {{!-- Spell picker — search the Spell compendiums and attach real,
            rollable Spell items to the NPC. --}}
      <div class="sde-spell-picker">
        <div class="sde-spell-picker-head">
          <span><i class="fas fa-book-sparkles"></i> Spells</span>
          {{#if spellPicker.selectedCount}}
            <span class="sde-spell-count" aria-label="{{spellPicker.selectedCount}} spells attached">{{spellPicker.selectedCount}}</span>
          {{/if}}
        </div>

        {{#if spellPicker.selectedCount}}
          <ul class="sde-spell-chips">
            {{#each spellPicker.selected}}
              <li class="sde-spell-chip">
                <img class="sde-spell-chip-img" src="{{this.img}}" alt="" width="20" height="20" loading="lazy" decoding="async">
                <span class="sde-spell-chip-name" title="{{this.name}}">{{this.name}}</span>
                <span class="sde-spell-chip-tier">{{this.tierLabel}}</span>
                <button type="button" class="sde-spell-chip-remove" data-action="creatorSpellRemove" data-uuid="{{this.uuid}}" aria-label="Remove {{this.name}}">
                  <i class="fas fa-xmark"></i>
                </button>
              </li>
            {{/each}}
          </ul>
        {{/if}}

        <div class="sde-spell-search-row">
          <input type="text" data-spell-search class="sde-spell-search" placeholder="Search spells…" value="{{spellPicker.search}}" aria-label="Search spells by name">
          <select data-spell-tier class="sde-spell-tier" aria-label="Filter spells by tier">
            <option value="" {{#unless spellPicker.tier}}selected{{/unless}}>All tiers</option>
            {{#each spellPicker.tierOptions}}
              <option value="{{this}}" {{#if (eq this ../spellPicker.tier)}}selected{{/if}}>Tier {{this}}</option>
            {{/each}}
          </select>
        </div>

        {{#if spellPicker.hasQuery}}
          {{#if spellPicker.resultCount}}
            <ul class="sde-spell-results">
              {{#each spellPicker.results}}
                <li class="sde-spell-result {{#if this.added}}is-added{{/if}}">
                  <img class="sde-spell-result-img" src="{{this.img}}" alt="" width="24" height="24" loading="lazy" decoding="async">
                  <span class="sde-spell-result-name" title="{{this.name}}">{{this.name}}</span>
                  <span class="sde-spell-result-meta">{{this.tierLabel}}{{#if this.rangeLabel}} • {{this.rangeLabel}}{{/if}}</span>
                  <span class="sde-spell-result-source" title="{{this.sourceLabel}}">{{this.sourceLabel}}</span>
                  <button type="button" class="sde-spell-add" data-action="creatorSpellAdd" data-uuid="{{this.uuid}}"
                          {{#if this.added}}disabled aria-label="{{this.name}} already attached"{{else}}aria-label="Attach {{this.name}}"{{/if}}>
                    <i class="fas {{#if this.added}}fa-check{{else}}fa-plus{{/if}}"></i>
                  </button>
                </li>
              {{/each}}
            </ul>
            {{#if spellPicker.capped}}
              <p class="sde-spell-hint">Showing first 40 matches — refine your search to narrow it.</p>
            {{/if}}
          {{else}}
            <p class="sde-spell-empty">No spells match.</p>
          {{/if}}
        {{else}}
          <p class="sde-spell-hint">Type to search the Spell compendiums, then click <i class="fas fa-plus"></i> to attach a rollable spell.</p>
        {{/if}}
      </div>
    </div>
  </details>

  {{!-- ═══ Description Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.description}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="description">
      <i class="fas fa-book-open"></i> Description
    </summary>
    <div class="sde-creator-section-body">
      <textarea data-draft-field="description" rows="6"
                placeholder="A short description and any flavor/special-ability text. Goes into the NPC's notes field on the actor sheet.">{{draft.description}}</textarea>
    </div>
  </details>

  {{!-- ═══ Save bar (sticky at bottom of panel) ═══ --}}
  <div class="sde-creator-footer">
    <div class="sde-creator-preview-line">{{draftPreview}}</div>
    <button type="button" class="sde-creator-save-btn" data-action="save">
      <i class="fas fa-floppy-disk"></i> Create World Actor
    </button>
  </div>

  {{/if}}{{!-- end of !_loaderOpen branch --}}

</div>
