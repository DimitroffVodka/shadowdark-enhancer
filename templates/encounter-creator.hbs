<div class="sde-creator">

  {{#if _loaderOpen}}

    {{!-- ═══ Bestiary Loader Takeover (1e-v) ═══════════════════════════
         When active, this view REPLACES the entire creator UI — closer
         to Vagabond's loader UX than the cramped popover it replaced.
         Pick a card to pre-fill the draft + return to the creator view. --}}
    <div class="sde-creator-loader-takeover">

      <header class="sde-creator-loader-bar">
        <button type="button" class="sde-creator-loader-cancel" data-action="creatorToggleLoader" title="Back to Creator">
          <i class="fas fa-arrow-left"></i> Back
        </button>
        <div class="sde-creator-loader-search-wrap">
          <i class="fas fa-magnifying-glass"></i>
          {{!-- Loader search uses data-loader-search (not data-draft-field)
               because it writes to this._loaderSearch, not this._draft. See
               _wireLoaderSearch + _prepareContext for the round-trip. --}}
          <input type="text" placeholder="Search bestiary…"
                 data-loader-search value="{{_loaderSearch}}">
        </div>
        <span class="sde-creator-loader-count">{{_loaderRows.length}} NPCs</span>
      </header>

      <div class="sde-creator-loader-grid sde-scrollbar">
        {{!-- Rows are pre-filtered + labelled in _prepareContext (JS).
             Each card is a button so it's keyboard-accessible. --}}
        {{#each _loaderRows}}
          <button type="button" class="sde-creator-loader-card" data-action="creatorLoaderPick" data-uuid="{{uuid}}" title="{{name}}">
            <img src="{{img}}" alt="" loading="lazy" />
            <span class="sde-creator-loader-card-name">{{name}}</span>
            <span class="sde-creator-loader-card-meta">{{displayLabel}}</span>
          </button>
        {{/each}}
        {{#if _loaderEmpty}}
          <div class="sde-creator-loader-empty">No matching NPCs in selected sources. Try widening the search or enabling more sources in the Browse NPCs tab.</div>
        {{/if}}
      </div>
    </div>

  {{else}}

    {{!-- ═══ Bestiary Loader Trigger (only shown when NOT in loader) ═══ --}}
    <div class="sde-creator-loader-wrapper">
      <button type="button" class="sde-creator-loader-btn" data-action="creatorToggleLoader">
        <i class="fas fa-book"></i> Load From Bestiary&hellip;
      </button>
    </div>

    {{!-- ═══ Identity Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.identity}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="identity">
      <i class="fas fa-id-card"></i> Identity
    </summary>
    <div class="sde-creator-section-body">

      <div class="sde-creator-row">
        <label>Name</label>
        <input type="text" data-draft-field="name" value="{{draft.name}}" placeholder="e.g. Frost Goblin">
      </div>

      <div class="sde-creator-row">
        <label>Alignment</label>
        <div class="sde-creator-align-group">
          {{#each alignments}}
            <label class="sde-creator-radio-label">
              <input type="radio" name="alignment" value="{{this}}"
                     {{#if (eq this ../draft.alignment)}}checked{{/if}}
                     data-draft-field="alignment">
              {{this}}
            </label>
          {{/each}}
        </div>
      </div>

      <div class="sde-creator-row">
        <label>Level</label>
        <input type="number" data-draft-field="level" value="{{draft.level}}" min="0" max="30">
      </div>

      <div class="sde-creator-row">
        <label>Portrait</label>
        <div class="sde-creator-img-picker">
          <img src="{{draft.img}}" width="48" height="48" alt="" />
          <input type="text" data-draft-field="img" value="{{draft.img}}" class="sde-creator-img-path">
          <button type="button" data-action="pickImg" title="Browse"><i class="fas fa-folder-open"></i></button>
        </div>
      </div>

      <div class="sde-creator-row">
        <label>Token image</label>
        <div class="sde-creator-img-picker">
          <img src="{{#if draft.tokenSrc}}{{draft.tokenSrc}}{{else}}{{draft.img}}{{/if}}" width="48" height="48" alt="" />
          <input type="text" data-draft-field="tokenSrc" value="{{draft.tokenSrc}}" placeholder="(inherits from portrait)" class="sde-creator-img-path">
          <button type="button" data-action="pickTokenSrc" title="Browse"><i class="fas fa-folder-open"></i></button>
        </div>
      </div>

    </div>
  </details>

  {{!-- ═══ Stats Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.stats}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="stats">
      <i class="fas fa-heart-pulse"></i> Stats
    </summary>
    <div class="sde-creator-section-body">

      <div class="sde-creator-row">
        <label>HP</label>
        <div class="sde-creator-hp-pair">
          <input type="number" data-draft-field="hp.value" value="{{draft.hp.value}}" min="0" title="Current HP">
          <span>/</span>
          <input type="number" data-draft-field="hp.max" value="{{draft.hp.max}}" min="1" title="Maximum HP">
        </div>
      </div>

      <div class="sde-creator-row">
        <label>AC</label>
        <input type="number" data-draft-field="ac" value="{{draft.ac}}" min="0">
      </div>

      <div class="sde-creator-row">
        <label>Abilities</label>
        <div class="sde-creator-ability-grid">
          {{#each (array "str" "dex" "con" "int" "wis" "cha")}}
            <div class="sde-creator-ability">
              <span class="sde-creator-ability-label">{{this}}</span>
              <input type="number" data-draft-field="abilities.{{this}}"
                     value="{{lookup ../draft.abilities this}}"
                     placeholder="0">
            </div>
          {{/each}}
        </div>
      </div>

      <div class="sde-creator-row">
        <label>Dark-Adapted</label>
        <input type="checkbox" data-draft-field="darkAdapted" {{#if draft.darkAdapted}}checked{{/if}}>
      </div>

    </div>
  </details>

  {{!-- ═══ Movement Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.movement}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="movement">
      <i class="fas fa-shoe-prints"></i> Movement
    </summary>
    <div class="sde-creator-section-body">
      <div class="sde-creator-row">
        <label>Type</label>
        <select data-draft-field="move">
          {{#each moveOptions}}
            <option value="{{this}}" {{#if (eq this ../draft.move)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="sde-creator-row">
        <label>Note</label>
        <input type="text" data-draft-field="moveNote" value="{{draft.moveNote}}" placeholder="e.g. climb, fly 60'">
      </div>
    </div>
  </details>

  {{!-- ═══ Actions Section (1e-iii) ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.actions}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="actions">
      <i class="fas fa-swords"></i> Actions
    </summary>
    <div class="sde-creator-section-body">

      {{!-- Quick Picks — iterate the catalog directly so additions /
           removals to ACTION_QUICK_PICKS don't require a template edit. --}}
      <div class="sde-creator-quick-picks">
        <label>Quick Add:</label>
        <div class="sde-creator-quick-grid">
          {{#each ACTION_QUICK_PICKS}}
            <button type="button" class="sde-creator-quick-btn"
                    data-action="creatorAddQuickPick" data-index="{{@index}}"
                    title="{{name}}{{#if (eq type 'NPC Attack')}} — {{num}}× +{{bonus}} {{damage}}{{/if}}{{#if description}} — {{description}}{{/if}}">
              <i class="fas {{icon}}"></i>
              <span class="sde-creator-quick-name">{{name}}</span>
            </button>
          {{/each}}
        </div>
      </div>

      {{!-- Action List --}}
      <div class="sde-creator-action-list">
        {{#each draft.actions}}
          <div class="sde-creator-action-card" data-id="{{id}}">
            <div class="sde-creator-action-header">
              <input type="text" data-draft-field="actions.{{@index}}.name" value="{{name}}" placeholder="Action Name">
              <button type="button" class="sde-creator-remove-btn" data-action="creatorRemoveAction" data-id="{{id}}">
                <i class="fas fa-trash"></i>
              </button>
            </div>

            {{#if (eq type "NPC Attack")}}
              <div class="sde-creator-action-grid">
                <div class="sde-creator-row-mini">
                  <label>Count</label>
                  <input type="number" data-draft-field="actions.{{@index}}.num" value="{{num}}" min="1">
                </div>
                <div class="sde-creator-row-mini">
                  <label>Atk</label>
                  <input type="number" data-draft-field="actions.{{@index}}.bonus" value="{{bonus}}">
                </div>
                <div class="sde-creator-row-mini">
                  <label>Damage</label>
                  <input type="text" data-draft-field="actions.{{@index}}.damage" value="{{damage}}" placeholder="1d6">
                </div>
              </div>
              {{!-- Range pills — iterate `ranges` (close/near/far/nearLine
                   from CONFIG.SHADOWDARK.RANGES), NOT the movement enum.
                   The array-checkbox handler in _wireFieldInputs toggles
                   the string value in/out of the slot's ranges array. --}}
              <div class="sde-creator-ranges">
                {{#each @root.ranges}}
                  <label class="sde-creator-range-pill {{#if (includes ../ranges this)}}active{{/if}}">
                    <input type="checkbox" data-draft-field="actions.{{@../index}}.ranges"
                           value="{{this}}" {{#if (includes ../ranges this)}}checked{{/if}} class="hidden">
                    {{this}}
                  </label>
                {{/each}}
              </div>
            {{/if}}

            <textarea data-draft-field="actions.{{@index}}.description" rows="2"
                      placeholder="Special effects, status conditions, or flavor text.">{{description}}</textarea>
          </div>
        {{else}}
          <div class="sde-creator-empty">No actions added yet.</div>
        {{/each}}
      </div>

      <div class="sde-creator-action-buttons">
        <button type="button" data-action="creatorAddAction"><i class="fas fa-plus"></i> Attack</button>
        <button type="button" data-action="creatorAddSpecial"><i class="fas fa-plus"></i> Special</button>
      </div>

    </div>
  </details>

  {{!-- ═══ Features Section (1e-iv) ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.features}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="features">
      <i class="fas fa-star"></i> Features
    </summary>
    <div class="sde-creator-section-body">

      {{!-- Quick Picks --}}
      <div class="sde-creator-quick-picks">
        <label>Quick Add:</label>
        <div class="sde-creator-quick-grid">
          {{#each FEATURE_QUICK_PICKS}}
            <button type="button" class="sde-creator-quick-btn"
                    data-action="creatorAddFeatureQuickPick" data-index="{{@index}}"
                    title="{{name}}: {{description}}">
              <i class="fas {{icon}}"></i>
            </button>
          {{/each}}
        </div>
      </div>

      {{!-- Feature List --}}
      <div class="sde-creator-action-list">
        {{#each draft.features}}
          <div class="sde-creator-action-card" data-id="{{id}}">
            <div class="sde-creator-action-header">
              <input type="text" data-draft-field="features.{{@index}}.name" value="{{name}}" placeholder="Feature Name">
              <button type="button" class="sde-creator-remove-btn" data-action="creatorRemoveFeature" data-id="{{id}}">
                <i class="fas fa-trash"></i>
              </button>
            </div>
            <textarea data-draft-field="features.{{@index}}.description" rows="2"
                      placeholder="Description of the feature effect.">{{description}}</textarea>
          </div>
        {{else}}
          <div class="sde-creator-empty">No features added yet.</div>
        {{/each}}
      </div>

      <div class="sde-creator-action-buttons">
        <button type="button" data-action="creatorAddFeature"><i class="fas fa-plus"></i> Custom Feature</button>
      </div>

    </div>
  </details>

  {{!-- ═══ Spellcasting Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.spellcasting}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="spellcasting">
      <i class="fas fa-wand-sparkles"></i> Spellcasting
    </summary>
    <div class="sde-creator-section-body">
      <div class="sde-creator-row">
        <label>Ability</label>
        <select data-draft-field="spellcasting.ability">
          <option value="" {{#unless draft.spellcasting.ability}}selected{{/unless}}>— None —</option>
          {{#each spellAbilities}}
            <option value="{{this}}" {{#if (eq this ../draft.spellcasting.ability)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>
      <div class="sde-creator-row">
        <label>Atk Bonus</label>
        <input type="number" data-draft-field="spellcasting.bonus" value="{{draft.spellcasting.bonus}}" {{#unless draft.spellcasting.ability}}disabled{{/unless}}>
      </div>
      <div class="sde-creator-row">
        <label>Attacks/round</label>
        <input type="number" data-draft-field="spellcasting.attacks" value="{{draft.spellcasting.attacks}}" min="0" {{#unless draft.spellcasting.ability}}disabled{{/unless}}>
      </div>
    </div>
  </details>

  {{!-- ═══ Description Section ═══ --}}
  <details class="sde-creator-section" {{#if sectionOpen.description}}open{{/if}}>
    <summary data-action="sectionToggle" data-section="description">
      <i class="fas fa-book-open"></i> Description
    </summary>
    <div class="sde-creator-section-body">
      <textarea data-draft-field="description" rows="6"
                placeholder="A short description and any flavor/special-ability text. Goes into the NPC's notes field on the actor sheet.">{{draft.description}}</textarea>
    </div>
  </details>

  {{!-- ═══ Save bar (sticky at bottom of panel) ═══ --}}
  <div class="sde-creator-footer">
    <button type="button" class="sde-creator-save-btn" data-action="save">
      <i class="fas fa-floppy-disk"></i> Create World Actor
    </button>
  </div>

  {{/if}}{{!-- end of !_loaderOpen branch --}}

</div>
