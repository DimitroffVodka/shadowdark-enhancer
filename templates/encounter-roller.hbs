<div class="sde-encounter-roller">

  {{!-- Tab Bar. Note: we deliberately do NOT use Foundry's `.tabs` class
       here — we handle tab switching ourselves in `_onRender`, and the
       `.tabs` class would risk Foundry's built-in Tabs handler attaching
       a duplicate click binding. --}}
  <nav class="sde-tabs" data-group="primary">
    <button type="button" class="item {{#if (eq activeTab 'tables')}}active{{/if}}" data-tab="tables" aria-pressed="{{#if (eq activeTab 'tables')}}true{{else}}false{{/if}}">
      <i class="fas fa-table-list"></i> Roll Tables
    </button>
    <button type="button" class="item {{#if (eq activeTab 'build')}}active{{/if}}" data-tab="build" aria-pressed="{{#if (eq activeTab 'build')}}true{{else}}false{{/if}}">
      <i class="fas fa-hammer"></i> Build Table
    </button>
    <button type="button" class="item {{#if (eq activeTab 'browse')}}active{{/if}}" data-tab="browse" aria-pressed="{{#if (eq activeTab 'browse')}}true{{else}}false{{/if}}">
      <i class="fas fa-user-group"></i> Browse NPCs
    </button>
    <button type="button" class="item {{#if (eq activeTab 'creator')}}active{{/if}}" data-tab="creator" aria-pressed="{{#if (eq activeTab 'creator')}}true{{else}}false{{/if}}">
      <i class="fas fa-wand-magic-sparkles"></i> Monster Creator
    </button>
  </nav>

  <hr>

  <section class="sde-content">

    {{!-- Roll Tables Tab --}}
    <div class="tab {{#if (eq activeTab 'tables')}}active{{/if}}" data-tab="tables">
      <div class="sde-control-row">
        <select name="selectedTable">
          {{#select selectedTableId}}
            <option value="">-- Select Table --</option>
            {{#each tableGroups}}
              <optgroup label="{{this.name}}">
                {{#each this.tables}}
                  <option value="{{this.uuid}}">{{#if this.isActive}}★ {{/if}}{{this.name}}</option>
                {{/each}}
              </optgroup>
            {{/each}}
          {{/select}}
        </select>
        <button type="button" data-action="setAsActive" {{#unless selectedTableId}}disabled{{/unless}}>
          Set as Active
        </button>
        <button type="button" class="sde-roll-btn" data-action="rollTable" {{#unless selectedTableId}}disabled{{/unless}}>
          <i class="fas fa-dice-d20"></i> Roll
        </button>
      </div>

      {{!-- Preview of what's actually in the selected table — visible
           always when a table is selected, so the GM isn't rolling blind. --}}
      {{#if tablePreview}}
        <div class="sde-table-preview">
          <header class="sde-preview-header">
            <span class="sde-preview-name">{{tablePreview.name}}</span>
            {{#if tablePreview.formula}}<span class="sde-preview-formula">({{tablePreview.formula}})</span>{{/if}}
          </header>
          <div class="sde-preview-rows">
            {{#each tablePreview.rows}}
              <div class="sde-preview-row {{#if this.flavor}}sde-preview-flavor{{/if}}" data-result-id="{{this.id}}">
                <span class="sde-preview-range">{{this.range}}</span>
                <span class="sde-preview-entry">{{this.name}}</span>
                <span class="sde-preview-appearing">{{#if this.appearing}}{{this.appearing}}{{/if}}</span>
                <span class="sde-preview-actions">
                  <button type="button" data-action="previewPost" title="Post this entry to chat"><i class="fas fa-clipboard-list"></i></button>
                  {{#unless this.flavor}}
                    <button type="button" data-action="previewPlace" title="Place tokens for this entry"><i class="fas fa-bullseye"></i></button>
                  {{/unless}}
                </span>
              </div>
            {{/each}}
          </div>
        </div>
      {{/if}}

      <div class="sde-result-panel">
        {{#if lastResult}}

          {{#if (eq lastResult.kind 'empty')}}
            <div class="sde-empty-state">Table draw produced no usable result — check the table contents</div>

          {{else if (eq lastResult.kind 'flavor')}}
            {{!-- Flavor card: pure text (e.g. environmental events). No
                 monster, no count, no facets — just the text + Post. --}}
            <div class="sde-result-card sde-result-flavor">
              <header class="sde-card-header">
                <h3>Environmental Result</h3>
                <div class="sde-header-actions">
                  <button type="button" data-action="postToChat" title="Post to Chat"><i class="fas fa-clipboard-list"></i> Post</button>
                </div>
              </header>
              <div class="sde-flavor-text">{{lastResult.text}}</div>
            </div>

          {{else}}
            {{!-- Monster card: full facets + Place button. --}}
            <div class="sde-result-card">
              <header class="sde-card-header">
                <h3>Encounter Result</h3>
                <div class="sde-header-actions">
                  <button type="button" data-action="postToChat" title="Post to Chat"><i class="fas fa-clipboard-list"></i> Post</button>
                  <button type="button" data-action="placeTokens" title="Place Tokens"><i class="fas fa-bullseye"></i> Place</button>
                </div>
              </header>

              <div class="sde-monster-row">
                <img src="{{lastResult.img}}" width="48" height="48" alt="{{lastResult.name}}" loading="lazy" decoding="async" />
                <div class="sde-monster-info">
                  <span class="sde-monster-count">{{lastResult.count}} ×</span>
                  <span class="sde-monster-name">{{lastResult.name}}</span>
                </div>
              </div>

              <div class="sde-facets">
                <div class="sde-facet-row">
                  <span class="sde-facet-label"><i class="fas fa-ruler-horizontal"></i> Distance</span>
                  <span class="sde-facet-roll">1d6 = {{lastResult.distanceRoll}}</span>
                  <span class="sde-facet-arrow">→</span>
                  <span class="sde-facet-result">{{lastResult.distanceText}}</span>
                  <button type="button" class="sde-reroll-btn" data-action="reroll" data-facet="distance" title="Reroll distance" aria-label="Reroll distance"><i class="fas fa-sync"></i></button>
                </div>

                <div class="sde-facet-row">
                  <span class="sde-facet-label"><i class="fas fa-masks-theater"></i> Activity</span>
                  <span class="sde-facet-roll">2d6 = {{lastResult.activityRoll}}</span>
                  <span class="sde-facet-arrow">→</span>
                  <span class="sde-facet-result">{{lastResult.activityText}}</span>
                  <button type="button" class="sde-reroll-btn" data-action="reroll" data-facet="activity" title="Reroll activity" aria-label="Reroll activity"><i class="fas fa-sync"></i></button>
                </div>

                <div class="sde-facet-row">
                  <span class="sde-facet-label"><i class="fas fa-comment"></i> Reaction</span>
                  <span class="sde-facet-roll">2d6+CHA = {{lastResult.reactionRoll}} + ({{lastResult.chaMod}})</span>
                  <span class="sde-facet-arrow">→</span>
                  <span class="sde-facet-result {{lastResult.reactionBand}}">{{lastResult.reactionBand}}</span>
                  <button type="button" class="sde-reroll-btn" data-action="reroll" data-facet="reaction" title="Reroll reaction" aria-label="Reroll reaction"><i class="fas fa-sync"></i></button>
                </div>
              </div>

              <div class="sde-stepper-row">
                <label for="sde-cha-mod">Apply CHA mod:</label>
                <div class="sde-stepper">
                  <button type="button" data-action="chaDec" aria-label="Decrease CHA mod"><i class="fas fa-caret-down"></i></button>
                  <input id="sde-cha-mod" type="number" name="chaMod" value="{{lastResult.chaMod}}" readonly aria-label="CHA modifier" />
                  <button type="button" data-action="chaInc" aria-label="Increase CHA mod"><i class="fas fa-caret-up"></i></button>
                </div>
              </div>
            </div>
          {{/if}}

        {{else}}
          <div class="sde-empty-state">Roll a table to see the result.</div>
        {{/if}}
      </div>
    </div>

    {{!-- Disabled Tabs --}}
    {{!-- Build Table Tab — Slice 1c --}}
    <div class="tab {{#if (eq activeTab 'build')}}active{{/if}}" data-tab="build">
      {{#if buildData}}

        <div class="sde-build-header">
          <div class="sde-build-header-row">
            <label class="sde-build-label" for="sde-build-die">Die:</label>
            <select id="sde-build-die" name="buildDie" class="sde-build-die-select">
              {{#each buildData.dice}}
                <option value="{{this.key}}" {{#if (eq this.key ../buildData.dieKey)}}selected{{/if}}>{{this.label}}</option>
              {{/each}}
            </select>

            <label class="sde-build-label" for="sde-build-name">Name:</label>
            <input id="sde-build-name"
                   type="text"
                   name="buildTableName"
                   class="sde-build-name-input"
                   placeholder="e.g. Forest Encounters"
                   value="{{buildData.tableName}}">

            <button type="button" class="sde-build-add-btn" data-action="buildAddSlot" title="Append a new slot">
              <i class="fas fa-plus"></i> Slot
            </button>
          </div>
        </div>

        <div class="sde-build-slots">
          {{#each buildData.slots}}
            <div class="sde-build-slot {{#if this.isEmpty}}sde-build-slot-empty{{/if}} {{#if this.isFlavor}}sde-build-slot-flavor{{/if}}" data-slot-idx="{{this.idx}}">

              {{!-- Range inputs (min / max) --}}
              <div class="sde-build-slot-range">
                <input type="number" data-slot-field="min" value="{{this.min}}" min="{{../buildData.die.min}}" max="{{../buildData.die.max}}" title="Lower bound" />
                <span class="sde-build-slot-range-sep">–</span>
                <input type="number" data-slot-field="max" value="{{this.max}}" min="{{../buildData.die.min}}" max="{{../buildData.die.max}}" title="Upper bound" />
              </div>

              {{!-- Entry body — switches on slot state --}}
              <div class="sde-build-slot-body">
                {{#if this.isEmpty}}
                  <input type="text"
                         class="sde-build-slot-text"
                         placeholder="Drop NPC here, or type entry text + Enter…">
                {{else if this.isFlavor}}
                  <span class="sde-build-slot-flavor-icon"><i class="fas fa-scroll"></i></span>
                  <span class="sde-build-slot-name">{{this.name}}</span>
                {{else}}
                  <span class="sde-build-slot-name">{{this.name}}</span>
                  <input type="text"
                         data-slot-field="appearing"
                         class="sde-build-slot-appearing"
                         placeholder="appearing (e.g. 1d4)"
                         value="{{this.appearing}}"
                         title="Roll formula for how many appear (e.g. 1d4)">
                {{/if}}
              </div>

              {{!-- Per-slot actions --}}
              <div class="sde-build-slot-actions">
                {{#if this.isMonster}}
                  <button type="button" data-action="buildPostSlot" title="Post this entry to chat"><i class="fas fa-clipboard-list"></i></button>
                  <button type="button" data-action="buildPlaceSlot" title="Place tokens for this entry"><i class="fas fa-bullseye"></i></button>
                {{else if this.isFlavor}}
                  <button type="button" data-action="buildPostSlot" title="Post this flavor entry to chat"><i class="fas fa-clipboard-list"></i></button>
                {{/if}}
                {{#unless this.isEmpty}}
                  <button type="button" data-action="buildClearSlot" title="Clear this slot's content"><i class="fas fa-eraser"></i></button>
                {{/unless}}
                <button type="button" data-action="buildRemoveSlot" title="Remove this slot entirely"><i class="fas fa-times"></i></button>
              </div>

            </div>
          {{/each}}

          {{#if (eq buildData.slots.length 0)}}
            <div class="sde-empty-state">No slots — click "+ Slot" or drag an NPC onto an empty slot row to start.</div>
          {{/if}}
        </div>

        {{#if buildData.warnings}}
          <ul class="sde-build-warnings">
            {{#each buildData.warnings}}
              <li><i class="fas fa-triangle-exclamation"></i> {{this}}</li>
            {{/each}}
          </ul>
        {{/if}}
        {{#if buildData.errors}}
          <ul class="sde-build-errors">
            {{#each buildData.errors}}
              <li><i class="fas fa-circle-xmark"></i> {{this}}</li>
            {{/each}}
          </ul>
        {{/if}}

        <div class="sde-build-footer">
          <button type="button" class="sde-build-save-btn" data-action="buildSave" {{#unless buildData.canSave}}disabled{{/unless}}>
            <i class="fas fa-floppy-disk"></i> Save as Roll Table
          </button>
        </div>

      {{/if}}
    </div>

    {{!-- Browse NPCs Tab (v2 — sidebar layout) --}}
    <div class="tab {{#if (eq activeTab 'browse')}}active{{/if}}" data-tab="browse">
      {{#if browseData}}

        <div class="sde-browse-v2">

          {{!-- ═══ Left Sidebar: Filters ═══ --}}
          <aside class="sde-browse-sidebar">
            <h3 class="sde-browse-sidebar-title">Filters</h3>

            {{!-- Sources (dropdown checkbox list) --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label">Sources</label>
              <details class="sde-browse-dropdown">
                <summary>{{browseData.sourcesLabel}}</summary>
                <div class="sde-browse-dropdown-menu">
                  {{#each browseData.availableSources}}
                    <label class="sde-browse-check">
                      <input type="checkbox"
                             {{#if (includes ../browseData.selectedSources this.id)}}checked{{/if}}
                             data-action="browseToggleSource"
                             data-source-id="{{this.id}}">
                      <span>{{this.label}}</span>
                    </label>
                  {{/each}}
                </div>
              </details>
            </div>

            {{!-- Search --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label" for="sde-br-search">Search</label>
              <input id="sde-br-search"
                     type="text"
                     name="browseSearch"
                     class="sde-browse-search"
                     placeholder="{{localize 'SDE.encounter.browse.search.placeholder'}}"
                     value="{{browseData.search}}">
            </div>

            {{!-- Alignment --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label">Alignment</label>
              <div class="sde-browse-align-group">
                {{#each (array "L" "N" "C")}}
                  <button type="button"
                          class="sde-browse-align-pill {{#if (includes ../browseData.alignment this)}}is-active{{/if}}"
                          data-action="browseToggleAlign"
                          aria-pressed="{{#if (includes ../browseData.alignment this)}}true{{else}}false{{/if}}"
                          data-alignment="{{this}}">{{this}}</button>
                {{/each}}
              </div>
            </div>

            {{!-- Level range --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label">Level</label>
              <div class="sde-browse-level-group">
                <input type="number" name="browseLevelMin" class="sde-browse-level-input" placeholder="min" aria-label="Minimum level" value="{{#unless (eq browseData.levelMin null)}}{{browseData.levelMin}}{{/unless}}">
                <span class="sde-browse-level-sep">–</span>
                <input type="number" name="browseLevelMax" class="sde-browse-level-input" placeholder="max" aria-label="Maximum level" value="{{#unless (eq browseData.levelMax null)}}{{browseData.levelMax}}{{/unless}}">
              </div>
            </div>

            <div class="sde-browse-filter-pair">
              <div class="sde-browse-filter">
                <label class="sde-browse-filter-label">HP</label>
                <div class="sde-browse-level-group">
                  <input type="number" name="browseHpMin" class="sde-browse-level-input" placeholder="min" aria-label="Minimum HP" value="{{#unless (eq browseData.hpMin null)}}{{browseData.hpMin}}{{/unless}}">
                  <span class="sde-browse-level-sep">–</span>
                  <input type="number" name="browseHpMax" class="sde-browse-level-input" placeholder="max" aria-label="Maximum HP" value="{{#unless (eq browseData.hpMax null)}}{{browseData.hpMax}}{{/unless}}">
                </div>
              </div>
              <div class="sde-browse-filter">
                <label class="sde-browse-filter-label">AC</label>
                <div class="sde-browse-level-group">
                  <input type="number" name="browseAcMin" class="sde-browse-level-input" placeholder="min" aria-label="Minimum AC" value="{{#unless (eq browseData.acMin null)}}{{browseData.acMin}}{{/unless}}">
                  <span class="sde-browse-level-sep">–</span>
                  <input type="number" name="browseAcMax" class="sde-browse-level-input" placeholder="max" aria-label="Maximum AC" value="{{#unless (eq browseData.acMax null)}}{{browseData.acMax}}{{/unless}}">
                </div>
              </div>
            </div>

            {{!-- Move filter --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label" for="sde-br-move">Movement</label>
              <select id="sde-br-move" name="browseMove" class="sde-browse-select">
                <option value="" {{#unless browseData.moves.length}}selected{{/unless}}>All movement</option>
                {{#each browseData.moveOptions}}
                  <option value="{{this}}" {{#if (includes ../browseData.moves this)}}selected{{/if}}>{{this}}</option>
                {{/each}}
              </select>
            </div>

            {{!-- Boolean toggles --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-check">
                <input type="checkbox"
                       {{#if browseData.darkAdapted}}checked{{/if}}
                       data-action="browseToggleDark">
                <span>Dark-Adapted</span>
              </label>
              <label class="sde-browse-check">
                <input type="checkbox"
                       {{#if browseData.hasSpellcasting}}checked{{/if}}
                       data-action="browseToggleSpellcaster">
                <span>Spellcaster</span>
              </label>
            </div>

            {{!-- Abilities (text-search NPC Feature names) --}}
            <div class="sde-browse-filter">
              <label class="sde-browse-filter-label" for="sde-br-ability">Abilities</label>
              <input id="sde-br-ability"
                     type="text"
                     name="browseAbilitySearch"
                     class="sde-browse-search"
                     placeholder="e.g. petrify, magic resistance"
                     value="{{browseData.abilitySearch}}">
            </div>
          </aside>

          {{!-- ═══ Right pane: Results table ═══ --}}
          <div class="sde-browse-results">
            <div class="sde-browse-count">
              {{browseData.filteredCount}} of {{browseData.totalCount}}
            </div>

            {{#if (eq browseData.selectedSources.length 0)}}
              <div class="sde-empty-state">{{localize 'SDE.encounter.browse.sources.empty'}}</div>
            {{else if (eq browseData.filteredCount 0)}}
              <div class="sde-empty-state">{{localize 'SDE.encounter.browse.empty'}}</div>
            {{else}}
              <table class="sde-browse-table">
                <thead>
                  <tr>
                    <th></th>
                    <th></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "name")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="name">Name {{#if (eq browseData.sortCol "name")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "level")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="level">LV {{#if (eq browseData.sortCol "level")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "alignment")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="alignment">Al {{#if (eq browseData.sortCol "alignment")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "hp")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="hp">HP {{#if (eq browseData.sortCol "hp")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "ac")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="ac">AC {{#if (eq browseData.sortCol "ac")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "dpr")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="dpr">DPR {{#if (eq browseData.sortCol "dpr")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                    <th aria-sort="{{#if (eq browseData.sortCol "attackCount")}}{{#if browseData.sortAsc}}ascending{{else}}descending{{/if}}{{else}}none{{/if}}"><button type="button" data-action="browseSort" data-column="attackCount">Attack {{#if (eq browseData.sortCol "attackCount")}}{{#if browseData.sortAsc}}▲{{else}}▼{{/if}}{{/if}}</button></th>
                  </tr>
                </thead>
                <tbody>
                  {{#each browseData.rows}}
                    <tr class="sde-browse-row" draggable="true" data-uuid="{{this.uuid}}">
                      <td class="sde-browse-action-cell">
                        <button type="button" class="sde-browse-add-btn" data-action="browseAddToBuild" title="Add to next empty Build Table slot">
                          <i class="fas fa-plus"></i>
                        </button>
                      </td>
                      <td><img src="{{this.img}}" width="24" height="24" alt="" loading="lazy" decoding="async" /></td>
                      <td class="sde-browse-name" title="{{this.name}}">{{this.name}}</td>
                      <td>{{this.levelLabel}}</td>
                      <td title="{{this.alignmentLabel}}">{{#if this.alignment}}{{this.alignment}}{{else}}—{{/if}}</td>
                      <td title="HP">{{this.hpLabel}}</td>
                      <td>{{this.acLabel}}</td>
                      <td>{{this.dprLabel}}</td>
                      <td class="sde-browse-atk-cell">
                        {{#if this.attackCount}}
                          <span class="sde-browse-atk-count" title="{{this.primaryAttack}}">{{this.attackSummary}}</span>
                          {{#if this.attackKinds.melee}}<i class="fas fa-swords sde-browse-atk-melee" title="Melee"></i>{{/if}}
                          {{#if this.attackKinds.ranged}}<i class="fas fa-crosshairs sde-browse-atk-ranged" title="Ranged"></i>{{/if}}
                          {{#if this.attackKinds.special}}<i class="fas fa-bolt sde-browse-atk-special" title="Special attack"></i>{{/if}}
                        {{else}}
                          <span class="sde-browse-atk-none">—</span>
                        {{/if}}
                        {{#if this.hasSpellcasting}}
                          <i class="fas fa-wand-sparkles sde-browse-atk-spell" title="Spellcaster (+{{this.spellcastingBonus}})"></i>
                        {{/if}}
                        {{#if this.darkAdapted}}
                          <i class="fas fa-moon sde-browse-atk-dark" title="Dark-Adapted"></i>
                        {{/if}}
                      </td>
                    </tr>
                  {{/each}}
                </tbody>
              </table>
            {{/if}}
          </div>

        </div>

      {{/if}}
    </div>

    {{!-- Monster Creator Tab — mounted inline by EncounterRollerApp --}}
    <div class="tab {{#if (eq activeTab 'creator')}}active{{/if}}" data-tab="creator">
      <div id="sde-monster-creator-host"></div>
    </div>

  </section>
</div>
