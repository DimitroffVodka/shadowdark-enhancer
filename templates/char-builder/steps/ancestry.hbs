<div class="sde-cb-anc">

  <div class="sde-cb-page-title sd-band">
    <h1>{{localize "SDE.charBuilder.step.ancestry"}}</h1>
  </div>

  {{!-- Always rendered — pre-selection it is invisible but keeps its height,
        so picking an option doesn't shove the whole body down. --}}
  <div class="sde-cb-anc-subhead sd-band sd-band--tight{{#unless step.hasSelection}} is-empty{{/unless}}">
    <h2>{{#if step.hasSelection}}{{step.detail.name}}{{else}}&nbsp;{{/if}}</h2>
  </div>

  <div class="sde-cb-anc-body">

    {{> sde-cb-list step.list}}

    <div class="sde-cb-anc-main">
      {{#if step.hasSelection}}

      <div class="sde-cb-anc-detail{{#if step.detail.hasPortrait}} with-portrait{{/if}}">
        <div class="sde-cb-anc-text">

          <div class="sde-cb-desc">{{{step.detail.description}}}</div>

          {{#if step.aside.languageText}}
          <p class="sde-cb-anc-langs">{{step.aside.languageText}}</p>
          {{/if}}

          {{#if step.aside.needsTalentChoice}}
          <p class="sde-cb-hint warn">{{localize "SDE.charBuilder.ancestry.chooseTraits"}} {{step.aside.talentChoiceCount}}</p>
          {{/if}}

          <div class="sde-cb-anc-traits">
            {{#each step.aside.traits}}
            <div class="sde-cb-anc-trait{{#if ../step.aside.needsTalentChoice}} choosable{{#if selected}} selected{{/if}}{{/if}}"
              {{#if ../step.aside.needsTalentChoice}}data-cb-anc-talent="{{uuid}}"{{/if}}>
              {{#if ../step.aside.needsTalentChoice}}{{#if selected}}<i class="fa-solid fa-check tsel"></i> {{else}}<i class="fa-regular fa-circle tsel"></i> {{/if}}{{/if}}<b class="tn">{{name}}.</b> {{{descInline}}}
            </div>
            {{/each}}
          </div>

          <div class="sde-cb-subfields">
            <label class="sde-cb-field wide">
              <span>{{localize "SDE.charBuilder.ancestry.name"}}</span>
              <div class="sde-cb-choicerow">
                <select data-cb-name-choice {{#unless step.canRollName}}disabled{{/unless}}>
                  <option value="">{{localize "SDE.charBuilder.chooseOption"}}</option>
                  {{#each step.nameOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
                </select>
                <input type="text" data-cb-name value="{{step.charName}}" placeholder="{{localize 'SDE.charBuilder.ancestry.namePlaceholder'}}">
                <button type="button" class="sde-cb-btn dice sm" data-cb-roll-name {{#unless step.canRollName}}disabled{{/unless}} title="{{localize 'SDE.charBuilder.ancestry.rollName'}}">
                  <i class="fa-solid fa-dice"></i>
                </button>
                {{#if step.lockedName}}
                <button type="button" class="sde-cb-btn sm" data-cb-unlock="{{step.lockedName.id}}" title="Locked — import the name table from Western Reaches pg {{step.lockedName.pages}}">
                  <i class="fa-solid fa-lock"></i> {{localize "SDE.charBuilder.unlock"}}
                </button>
                {{/if}}
              </div>
            </label>
            <label class="sde-cb-field wide">
              <span>{{localize "SDE.charBuilder.ancestry.trinket"}}</span>
              <div class="sde-cb-choicerow">
                <select data-cb-trinket-choice {{#unless step.canRollTrinket}}disabled{{/unless}}>
                  <option value="">{{localize "SDE.charBuilder.chooseOption"}}</option>
                  {{#each step.trinketOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
                </select>
                <input type="text" data-cb-trinket value="{{step.trinket}}" placeholder="{{localize 'SDE.charBuilder.ancestry.trinketPlaceholder'}}">
                <button type="button" class="sde-cb-btn dice sm" data-cb-roll-trinket {{#unless step.canRollTrinket}}disabled{{/unless}} title="{{localize 'SDE.charBuilder.ancestry.rollTrinket'}}">
                  <i class="fa-solid fa-dice"></i>
                </button>
                {{#if step.lockedTrinket}}
                <button type="button" class="sde-cb-btn sm" data-cb-unlock="{{step.lockedTrinket.id}}" title="Locked — import the trinket table from Western Reaches pg {{step.lockedTrinket.pages}}">
                  <i class="fa-solid fa-lock"></i> {{localize "SDE.charBuilder.unlock"}}
                </button>
                {{/if}}
              </div>
            </label>
          </div>

        </div>

        {{#if step.detail.hasPortrait}}
        <div class="sde-cb-anc-portrait">
          <img src="{{step.detail.img}}" alt="{{step.detail.name}}">
        </div>
        {{/if}}
      </div>

      {{else}}
      <div class="sde-cb-empty">{{localize "SDE.charBuilder.selectPrompt"}}</div>
      {{/if}}
    </div>

  </div>
</div>
