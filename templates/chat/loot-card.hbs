<div class="sde-loot-card">
  <header class="sde-loot-head"><i class="fas fa-coins"></i> {{#if source}}{{source}} — {{/if}}Loot — Treasure {{tier}}</header>

  {{#if items.length}}
  <ul class="sde-loot-items">
    {{#each items as |it|}}
    <li class="sde-loot-row" data-item-index="{{it.idx}}">
      <img src="{{it.img}}" width="28" height="28" alt="">
      <span class="sde-loot-name">{{it.name}}{{it.qtyLabel}}<span class="sde-loot-value">{{it.valueLabel}}</span><span class="sde-loot-feature">{{it.featureLabel}}</span></span>
      {{#if it.claimedBy}}
      <span class="sde-loot-claimed"><i class="fas fa-check"></i> {{it.claimedByName}}</span>
      {{else}}
      <button type="button" class="sde-loot-claim" data-item-index="{{it.idx}}">
        <i class="fas fa-hand-holding"></i> Claim
      </button>
      <button type="button" class="sde-loot-give sde-loot-gm" data-item-index="{{it.idx}}">
        <i class="fas fa-gift"></i> Give
      </button>
      {{#if it.forgeable}}
      <button type="button" class="sde-loot-forge sde-loot-gm" data-item-index="{{it.idx}}">
        <i class="fas fa-hammer"></i> Forge
      </button>
      {{/if}}
      {{/if}}
    </li>
    {{/each}}
  </ul>
  {{/if}}

  {{#if hasCoins}}
  <div class="sde-loot-coins">
    <span class="sde-loot-coinlabel"><i class="fas fa-coins"></i> {{coinsLabel}}</span>
    {{#if coinsAssigned}}
    <span class="sde-loot-claimed"><i class="fas fa-arrow-right"></i> {{coinsAssigned.actorName}}</span>
    {{else}}
    <button type="button" class="sde-loot-claim-coins">
      <i class="fas fa-hand-holding"></i> Claim
    </button>
    <span class="sde-loot-gm">
      <select class="sde-loot-coins-actor" aria-label="Assign coins to">
        {{#each party as |p|}}<option value="{{p.id}}">{{p.name}}</option>{{/each}}
      </select>
      <button type="button" class="sde-loot-assign-coins">Assign</button>
    </span>
    {{/if}}
  </div>
  {{/if}}

  {{#if notes.length}}
  <ul class="sde-loot-notes">
    {{#each notes as |n|}}<li>{{n}}</li>{{/each}}
  </ul>
  {{/if}}

  {{#if hasTotals}}
  <div class="sde-loot-total"><i class="fas fa-coins"></i> Hoard: {{totalGp}} gp · {{totalXp}} XP</div>
  {{/if}}
</div>
