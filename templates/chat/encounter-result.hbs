<div class="sde-encounter-chat-card">
  <header class="sde-chat-header">
    <h3><i class="fas fa-dragon"></i> Encounter</h3>
  </header>

  <div class="sde-chat-monster">
    <img src="{{img}}" width="40" height="40" alt="" />
    <div class="sde-chat-monster-info">
      <span class="sde-chat-monster-count">{{count}} ×</span>
      <span class="sde-chat-monster-name">{{name}}</span>
    </div>
  </div>

  <div class="sde-chat-facets">
    <div class="sde-chat-facet">
      <span class="sde-chat-facet-label"><i class="fas fa-ruler-horizontal"></i> Distance</span>
      <span class="sde-chat-facet-result">{{distanceText}}</span>
      <span class="sde-chat-facet-roll">({{distanceRoll}})</span>
    </div>
    <div class="sde-chat-facet">
      <span class="sde-chat-facet-label"><i class="fas fa-masks-theater"></i> Activity</span>
      <span class="sde-chat-facet-result">{{activityText}}</span>
      <span class="sde-chat-facet-roll">({{activityRoll}})</span>
    </div>
    <div class="sde-chat-facet">
      <span class="sde-chat-facet-label"><i class="fas fa-comment"></i> Reaction</span>
      <span class="sde-chat-facet-result sde-reaction-{{reactionBand}}">{{reactionBand}}</span>
      <span class="sde-chat-facet-roll">({{reactionRoll}} + {{chaMod}})</span>
    </div>
  </div>
</div>
