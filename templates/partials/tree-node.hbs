{{!-- Recursive Manage-tree node. Invoked as {{> sdeTreeNode node=<node> }}.
      node: { id, label, icon, depth, expandable, expanded, have, locked,
              placeholder?, note?, children:[node], entries:[{name,seedAction,type,src,pages}] }
      Self-recurses on node.children; leaf nodes list locked entries with an
      Unlock button reusing the existing seed handlers. --}}
<div class="sde-mtree-node depth-{{node.depth}}">
  <div class="sde-mtree-row{{#if node.expandable}} is-expandable{{/if}}"
       {{#if node.expandable}}data-action="manageNodeExpand" data-node-id="{{node.id}}"{{/if}}>
    <i class="fas {{#if node.expandable}}{{#if node.expanded}}fa-caret-down{{else}}fa-caret-right{{/if}}{{else}}fa-caret-right sde-mtree-caret-hidden{{/if}} sde-mtree-caret"></i>
    <i class="fas {{node.icon}} sde-mtree-icon"></i>
    <span class="sde-mtree-label">{{node.label}}</span>
    <span class="sde-mtree-chips">
      <span class="sde-mtree-chip unlocked" title="Unlocked — present in this world / the suite">
        <i class="fas fa-lock-open"></i> {{node.have}}</span>
      <span class="sde-mtree-chip locked{{#if node.locked}} has{{/if}}" title="Locked — known content not yet imported">
        <i class="fas fa-lock"></i> {{node.locked}}</span>
    </span>
  </div>

  {{#if node.expanded}}
  <div class="sde-mtree-children">
    {{#if node.placeholder}}
    <p class="sde-mtree-note"><i class="fas fa-circle-info"></i> {{node.note}}</p>
    {{/if}}
    {{#each node.children as |child|}}
      {{> sdeTreeNode node=child}}
    {{/each}}
    {{#if node.entries.length}}
    <ul class="sde-mtree-entries">
      {{#each node.entries as |e|}}
      <li class="sde-mtree-entry {{#if e.present}}is-present{{else}}is-locked{{/if}}">
        <i class="fas {{#if e.present}}fa-circle-check{{else}}fa-lock{{/if}} sde-mtree-entry-mark"></i>
        <span class="sde-mtree-entry-name">{{e.name}}</span>
        {{#if e.pages}}<span class="sde-mtree-entry-pg" title="Page in the source book">pg {{e.pages}}</span>{{/if}}
        {{#if e.present}}
        <span class="sde-mtree-entry-tag">imported</span>
        {{else}}
        <button type="button" class="sde-mtree-unlock"
                data-action="{{e.seedAction}}" data-name="{{e.name}}"
                data-type="{{e.type}}" data-src="{{e.src}}" data-pages="{{e.pages}}"
                title="Unlock “{{e.name}}” — seeds the Import paste box">
          <i class="fas fa-unlock"></i> Unlock
        </button>
        {{/if}}
      </li>
      {{/each}}
    </ul>
    {{/if}}
  </div>
  {{/if}}
</div>
