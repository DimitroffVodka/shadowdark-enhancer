{{!-- Shared catalog accordion for the manifest-driven dashboards.
      Invoked as: {{> sdeCatalog data=<tabData> icon="fa-…" noun="monster"}}
      All #each blocks use `as |x|` so the partial context (`data`) stays
      reachable at every depth. --}}

<div class="sde-thub-summary">
  <button type="button" class="sde-thub-stat {{#if data.fAll}}active{{/if}}" data-action="filter" data-state="all">
    <i class="fas fa-list"></i> {{data.summary.total}} catalogued</button>
  <button type="button" class="sde-thub-stat ok {{#if data.fSystem}}active{{/if}}" data-action="filter" data-state="system">
    <i class="fas fa-box-archive"></i> {{data.summary.system}} in system</button>
  <button type="button" class="sde-thub-stat imp {{#if data.fImported}}active{{/if}}" data-action="filter" data-state="imported">
    <i class="fas fa-check"></i> {{data.summary.imported}} {{#if data.builtLabel}}{{data.builtLabel}}{{else}}imported{{/if}}</button>
  <button type="button" class="sde-thub-stat miss {{#if data.fMissing}}active{{/if}}" data-action="filter" data-state="missing">
    <i class="fas fa-circle-exclamation"></i> {{data.summary.missing}} missing</button>
</div>

{{#if data.summary.draft}}
<p class="sde-import-note sde-thub-missing-note">
  <i class="fas fa-flask"></i>
  <strong>Draft catalog.</strong> Bootstrapped from the content inventory (names + pages, approximate).
  “Missing” means it isn’t in your suite or the system yet{{#if data.seedAction}} — click
  <i class="fas fa-file-import"></i> Import to paste it from your book{{/if}}. Fix names/pages as you go.
</p>
{{/if}}

{{#each data.groups as |g|}}
<details class="sde-thub-cat" open>
  <summary class="sde-thub-cat-head">
    <i class="fas fa-caret-right sde-thub-caret"></i>
    <span class="sde-thub-cat-name">{{g.label}}</span>
    <span class="sde-thub-cat-count">{{g.count}}</span>
  </summary>
  {{#each g.subgroups as |sg|}}
  <details class="sde-thub-sub" open>
    <summary class="sde-thub-sub-head">
      <i class="fas fa-caret-right sde-thub-caret"></i>
      <span class="sde-thub-sub-name">{{sg.sub}}</span>
      <span class="sde-thub-sub-count">{{sg.rows.length}}</span>
    </summary>
    <ul class="sde-thub-rows">
      {{#each sg.rows as |r|}}
      <li class="sde-thub-row state-{{r.state}}">
        <span class="sde-thub-name">{{r.name}}{{#if r.dims}} <span class="sde-thub-src-n">{{r.dims}}</span>{{/if}}</span>
        <span class="sde-thub-meta">{{#if r.page}}p{{r.page}} &middot; {{/if}}{{r.category}}</span>
        {{#if (eq r.state "system")}}
        <span class="sde-thub-badge ok"><i class="fas fa-box-archive"></i> In system</span>
        {{/if}}
        {{#if (eq r.state "imported")}}
        <span class="sde-thub-badge imp"><i class="fas fa-check"></i> {{r.presentLabel}}</span>
        {{/if}}
        {{#if (eq r.state "missing")}}
        <span class="sde-thub-badge miss"><i class="fas fa-circle-exclamation"></i> Missing</span>
        {{#if r.importAction}}
        <button type="button" class="sde-thub-import" data-action="{{r.importAction}}" data-name="{{r.name}}"
                title="Seed the paste box to import {{r.name}}">
          <i class="fas fa-file-import"></i> Import
        </button>
        {{/if}}
        {{/if}}
      </li>
      {{/each}}
    </ul>
  </details>
  {{/each}}
</details>
{{/each}}

{{#unless data.groups.length}}
<p class="sde-hub-monsters-empty">Nothing matches the current filter.</p>
{{/unless}}
