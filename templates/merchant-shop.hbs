<div class="sdems-container">

  {{!-- Header --}}
  <div class="sdems-header">
    <i class="fas fa-shop sdems-header-icon"></i>
    <h2 class="sdems-title">{{shopName}}</h2>
    {{#if hasActor}}
    <span class="sdems-wallet"><i class="fas fa-coins"></i> {{actorName}}: {{walletDetail}}</span>
    {{else}}
    <span class="sdems-wallet sdems-no-actor"><i class="fas fa-user-slash"></i> No character</span>
    {{/if}}
  </div>

  {{!-- Tabs --}}
  <div class="sdems-tab-bar">
    {{#each tabs}}
    <button class="sdems-tab-btn {{#if active}}active{{/if}}" data-tab="{{id}}" type="button">
      <i class="fas {{icon}}"></i> {{label}}
    </button>
    {{/each}}
  </div>

  {{!-- Tab content --}}
  <div class="sdems-body">

    {{!-- ═══ BUY TAB ═══ --}}
    {{#if (eq tab "buy")}}
    <div class="sdems-tab-content sdems-buy-tab">

      {{!-- Filters --}}
      <div class="sdems-filters">
        <input type="text" class="sdems-search-input" placeholder="Search items…" value="{{searchFilter}}">
        <select class="sdems-category-select">
          <option value="all">All Categories</option>
          {{#each categories}}
          <option value="{{this}}" {{#if (eq this ../categoryFilter)}}selected{{/if}}>{{this}}</option>
          {{/each}}
        </select>
      </div>

      {{!-- Item list, grouped into collapsible category sections --}}
      <div class="sdems-item-list">
        {{#if inventoryCount}}
        {{#each inventorySections}}
        <div class="sdems-shop-section {{#if collapsed}}sdems-section-collapsed{{/if}}" data-section="{{key}}">
          <div class="sdems-section-header" data-section-toggle="{{key}}" role="button" tabindex="0"
               aria-expanded="{{#if collapsed}}false{{else}}true{{/if}}">
            <i class="fas fa-chevron-down sdems-section-caret"></i>
            <span class="sdems-section-title">{{label}}</span>
            <span class="sdems-section-count">{{count}}</span>
          </div>
          <div class="sdems-section-body">
            {{#each items}}
            <div
              class="sdems-item-row {{#if outOfStock}}sdems-out-of-stock{{/if}} {{#unless canAfford}}sdems-cant-afford{{/unless}}"
              data-shop-item-id="{{id}}">
              <img class="sdems-item-icon" src="{{img}}" alt="{{name}}" width="32" height="32">
              <div class="sdems-item-info">
                <span class="sdems-item-name">{{name}}</span>
                <span class="sdems-item-cat">{{category}}</span>
              </div>
              <span class="sdems-item-price">{{priceDisplay}}</span>
              <span class="sdems-item-stock" title="{{#if outOfStock}}Out of stock{{else}}{{#if (eq stockDisplay "
                ∞")}}Unlimited{{else}}{{stockDisplay}} remaining{{/if}}{{/if}}">
                {{stockDisplay}}
              </span>
              <div class="sdems-item-actions">
                <input type="number" class="sdems-qty-input" value="1" min="1" max="99">
                <button class="sdems-buy-btn" type="button" {{#unless canAfford}}disabled{{/unless}}>
                  <i class="fas fa-cart-plus"></i> Buy
                </button>
              </div>
            </div>
            {{/each}}
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="sdems-empty">
          <i class="fas fa-shop-slash"></i>
          <p>No items available.</p>
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- ═══ CATALOG TAB ═══ --}}
    {{#if (eq tab "catalog")}}
    <div class="sdems-tab-content sdems-catalog-tab">

      {{!-- Filters --}}
      <div class="sdems-catalog-filters">
        <select class="sdems-catalog-pack">
          <option value="all" {{#if (eq catalogPack "all" )}}selected{{/if}}>All Packs</option>
          {{#each catalogPacks}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>

        {{#if showFolderFilter}}
        <select class="sdems-catalog-folder">
          <option value="all" {{#if (eq catalogFolder "all" )}}selected{{/if}}>All Folders</option>
          {{#each catalogFolders}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}}</option>
          {{/each}}
        </select>
        {{/if}}

        <input type="text" class="sdems-catalog-search" placeholder="Search items…" value="{{catalogSearch}}">

        <select class="sdems-catalog-sort">
          <option value="name" {{#if (eq catalogSort "name" )}}selected{{/if}}>Name</option>
          <option value="value-asc" {{#if (eq catalogSort "value-asc" )}}selected{{/if}}>Value ↑</option>
          <option value="value-desc" {{#if (eq catalogSort "value-desc" )}}selected{{/if}}>Value ↓</option>
        </select>
      </div>

      {{!-- Item list --}}
      <div class="sdems-item-list">
        {{#if catalogItems.length}}
        {{#each catalogItems}}
        <div class="sdems-item-row {{#unless canAfford}}sdems-cant-afford{{/unless}}" data-item-uuid="{{uuid}}">
          <img class="sdems-item-icon" src="{{img}}" alt="{{name}}" width="32" height="32">
          <div class="sdems-item-info">
            <span class="sdems-item-name">{{name}}</span>
            <span class="sdems-item-cat">
              <span class="sdems-catalog-tag">{{packLabel}}</span>
              {{#if folderName}}<span class="sdems-catalog-tag sdems-folder-tag">{{folderName}}</span>{{/if}}
            </span>
          </div>
          <span class="sdems-item-price">{{priceDisplay}}</span>
          <div class="sdems-item-actions">
            <input type="number" class="sdems-qty-input" value="1" min="1" max="99">
            <button class="sdems-catalog-buy-btn" type="button" {{#unless canAfford}}disabled{{/unless}}>
              <i class="fas fa-cart-plus"></i> Buy
            </button>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="sdems-empty">
          <i class="fas fa-book-open"></i>
          <p>No items match your filters.</p>
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- ═══ GAMBLE TAB ═══ --}}
    {{#if (eq tab "gamble")}}
    <div class="sdems-tab-content sdems-gamble-tab">
      <div class="sdems-gamble-header">
        <i class="fas fa-dice"></i> Pay gold to roll on a loot table. You might get treasure, weapons, armor, or
        alchemy!
      </div>
      <div class="sdems-item-list">
        {{#if gambleOptions.length}}
        {{#each gambleOptions}}
        <div class="sdems-item-row {{#unless canAfford}}sdems-cant-afford{{/unless}}" data-gamble-id="{{id}}">
          <div class="sdems-item-info">
            <span class="sdems-item-name">{{name}}</span>
          </div>
          <span class="sdems-item-price">{{costDisplay}}</span>
          <div class="sdems-item-actions">
            <button class="sdems-gamble-btn" type="button" {{#unless canAfford}}disabled{{/unless}}>
              <i class="fas fa-dice"></i> Gamble
            </button>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="sdems-empty">
          <i class="fas fa-dice"></i>
          <p>No gamble options configured. The GM can set them up on the Manage tab.</p>
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- ═══ SELL TAB ═══ --}}
    {{#if (eq tab "sell")}}
    <div class="sdems-tab-content sdems-sell-tab">

      <div class="sdems-sell-header">
        <span>Your Equipment</span>
        <span class="sdems-sell-ratio">Sell Ratio: <strong>{{sellRatio}}%</strong></span>
        {{#if hasJunk}}
        <button class="sdems-sell-all-junk" type="button">
          <i class="fas fa-trash-can"></i> Sell All Junk
        </button>
        {{/if}}
      </div>

      <div class="sdems-item-list">
        {{#if sellItems.length}}
        {{#each sellItems}}
        <div class="sdems-item-row {{#if isJunk}}sdems-junk-item{{/if}}" data-item-id="{{id}}">
          <img class="sdems-item-icon" src="{{img}}" alt="{{name}}" width="32" height="32">
          <div class="sdems-item-info">
            <span class="sdems-item-name">{{#if isJunk}}<i class="fas fa-trash-can"
                style="color:#e74c3c;margin-right:4px;"></i>{{/if}}{{name}}{{#if (gt quantity 1)}}
              ×{{quantity}}{{/if}}</span>
            <span class="sdems-item-cat">Value: {{costDisplay}}</span>
          </div>
          <span class="sdems-item-price sdems-sell-price">{{sellPriceDisplay}}</span>
          <div class="sdems-item-actions">
            <input type="number" class="sdems-qty-input" value="1" min="1" max="{{quantity}}">
            <button class="sdems-sell-btn" type="button">
              <i class="fas fa-coins"></i> Sell
            </button>
          </div>
        </div>
        {{/each}}
        {{else}}
        <div class="sdems-empty">
          <i class="fas fa-box-open"></i>
          <p>Nothing to sell.</p>
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- ═══ LOG TAB ═══ --}}
    {{#if (eq tab "log")}}
    <div class="sdems-tab-content sdems-log-tab">

      <div class="sdems-log-toolbar">
        <button class="sdems-copy-discord" type="button">
          <i class="fab fa-discord"></i> Shop Log
        </button>
        <button class="sdems-copy-session" type="button">
          <i class="fab fa-discord"></i> Session Summary
        </button>
        {{#if isGM}}
        <button class="sdems-clear-log" type="button">
          <i class="fas fa-trash"></i> Clear Log
        </button>
        {{/if}}
      </div>

      <div class="sdems-log-list">
        {{#if logEntries.length}}
        {{#each logEntries}}
        <div class="sdems-log-entry">
          <span class="sdems-log-time">{{time}}</span>
          <span class="sdems-log-icon {{#if isBuy}}sdems-log-buy{{else}}sdems-log-sell{{/if}}">
            <i class="fas {{#if isBuy}}fa-cart-shopping{{else}}fa-coins{{/if}}"></i>
          </span>
          <span class="sdems-log-player">{{player}}</span>
          <span class="sdems-log-action">{{#if isBuy}}bought{{else}}sold{{/if}}</span>
          <span class="sdems-log-detail">{{item}}{{qtyStr}}</span>
          <span class="sdems-log-price">{{priceDisplay}}</span>
        </div>
        {{/each}}
        {{else}}
        <div class="sdems-empty">
          <i class="fas fa-clipboard-list"></i>
          <p>No transactions recorded.</p>
        </div>
        {{/if}}
      </div>
    </div>
    {{/if}}

    {{!-- ═══ MANAGE TAB (GM) ═══ --}}
    {{#if (eq tab "manage")}}
    <div class="sdems-tab-content sdems-manage-tab">

      {{!-- Shop config --}}
      <div class="sdems-manage-section">
        <div class="sdems-manage-row">
          <label>Shop Name</label>
          <input type="text" class="sdems-shop-name-input" value="{{shopName}}">
        </div>
        <div class="sdems-manage-row">
          <label>Buy Markup (%)</label>
          <input type="number" class="sdems-markup-input" value="{{buyMultiplier}}" min="10" max="500" step="10">
          <span style="font-size:0.85em;color:var(--vcb-text-muted,#666);">100 = normal, 150 = markup, 80 =
            discount</span>
        </div>
        <div class="sdems-manage-row">
          <label>Sell Ratio (%)</label>
          <input type="number" class="sdems-ratio-input" value="{{sellRatio}}" min="0" max="100" step="5">
        </div>
        <div class="sdems-manage-row">
          <label>Player Catalog</label>
          <label class="sdems-toggle-label">
            <input type="checkbox" class="sdems-catalog-toggle" {{#if catalogEnabled}}checked{{/if}}>
            Allow players to browse the full compendium catalog
          </label>
        </div>
        <div class="sdems-manage-row">
          <label>Gamble Table</label>
          <label class="sdems-toggle-label">
            <input type="checkbox" class="sdems-gamble-toggle" {{#if gambleEnabled}}checked{{/if}}>
            Allow players to gamble on loot tables
          </label>
        </div>
      </div>

      {{!-- Mode selector --}}
      <div class="sdems-manage-section">
        <h3>Inventory Source</h3>
        <div class="sdems-mode-selector">
          <label>
            <input type="radio" class="sdems-mode-radio" name="sdems-mode" value="compendium" {{#if (eq mode "compendium"
              )}}checked{{/if}}>
            Compendium Inventory
          </label>
          <label>
            <input type="radio" class="sdems-mode-radio" name="sdems-mode" value="actor" {{#if (eq mode "actor"
              )}}checked{{/if}}>
            NPC Actor Inventory
          </label>
        </div>

        {{#if (eq mode "actor")}}
        <select class="sdems-actor-select">
          <option value="">— Select Actor —</option>
          {{#each npcActors}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{name}} ({{type}})</option>
          {{/each}}
        </select>
        {{/if}}
      </div>

      {{#if (eq mode "compendium")}}
      {{!-- Saved merchants --}}
      <div class="sdems-manage-section">
        <h3>Saved Merchants</h3>
        <div class="sdems-saved-configs-row">
          <select class="sdems-load-config-select">
            <option value="">— Select merchant —</option>
            {{#each savedConfigs}}
            <option value="{{@key}}">{{this.name}}</option>
            {{/each}}
          </select>
          <button class="sdems-load-merchant-btn" type="button">
            <i class="fas fa-upload"></i> Load
          </button>
          <button class="sdems-delete-merchant-btn" type="button">
            <i class="fas fa-trash"></i> Delete
          </button>
        </div>
      </div>
      {{/if}}

      {{!-- Broadcast controls --}}
      <div class="sdems-manage-section sdems-broadcast-controls">
        <button class="sdems-open-for-all" type="button">
          <i class="fas fa-bullhorn"></i>Make Shop Available
        </button>
        <button class="sdems-close-for-all" type="button">
          <i class="fas fa-door-closed"></i>Close Shop
        </button>
        <button class="sdems-save-config-btn" type="button">
          <i class="fas fa-book"></i>Save
        </button>
      </div>

      {{!-- Compendium mode: inventory editor --}}
      {{#if (eq mode "compendium")}}
      <div class="sdems-manage-section">
        <h3>Shop Inventory</h3>

        {{!-- Drop zone --}}
        <div class="sdems-drop-zone">
          <i class="fas fa-cloud-arrow-down"></i> Drag items from compendium here
        </div>

        {{!-- Current inventory --}}
        <div class="sdems-manage-inventory">
          {{#each inventory}}
          <div class="sdems-manage-item-row" data-shop-item-id="{{id}}">
            <img src="{{img}}" alt="{{name}}" width="24" height="24">
            <span class="sdems-manage-item-name">{{name}}</span>
            <div class="sdems-manage-price">
              <input type="number" class="sdems-price-gold" value="{{cost.gp}}" min="0" title="Gold"
                placeholder="gp">
              <span>gp</span>
              <input type="number" class="sdems-price-silver" value="{{cost.sp}}" min="0" title="Silver"
                placeholder="sp">
              <span>sp</span>
              <input type="number" class="sdems-price-copper" value="{{cost.cp}}" min="0" title="Copper"
                placeholder="cp">
              <span>cp</span>
            </div>
            <div class="sdems-manage-stock">
              <input type="number" class="sdems-stock-input" value="{{stock}}" min="-1" title="Stock (-1 = unlimited)">
              <span class="sdems-stock-hint">(-1 = ∞)</span>
            </div>
            <button class="sdems-remove-item-btn" type="button" title="Remove from shop">
              <i class="fas fa-xmark"></i>
            </button>
          </div>
          {{/each}}
        </div>

        {{!-- Compendium browser --}}
        <h3>Add from Compendium</h3>
        <div class="sdems-comp-browser">
          <div class="sdems-comp-controls">
            <select class="sdems-pack-select">
              {{#each compendiumPacks}}
              <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
              {{/each}}
            </select>
            <input type="text" class="sdems-comp-search" placeholder="Filter…" value="{{compendiumFilter}}">
          </div>
          <div class="sdems-comp-list">
            {{#each compendiumItems}}
            <div class="sdems-comp-item">
              <img src="{{img}}" alt="{{name}}" width="20" height="20">
              <span>{{name}}</span>
              <button class="sdems-add-item-btn" type="button" data-uuid="{{uuid}}" title="Add to shop">
                <i class="fas fa-plus"></i>
              </button>
            </div>
            {{/each}}
          </div>
        </div>
      </div>
      {{/if}}

      {{!-- Gamble options config --}}
      <div class="sdems-manage-section">
        <h3>Gamble Options</h3>

        {{!-- Existing options --}}
        <div class="sdems-manage-inventory">
          {{#each gambleOptions}}
          <div class="sdems-manage-item-row" data-gamble-config-id="{{id}}">
            <span class="sdems-manage-item-name">{{name}}</span>
            <div class="sdems-manage-price">
              <input type="number" class="sdems-gamble-cost-gold" value="{{cost.gp}}" min="0" title="Gold"
                placeholder="gp">
              <span>gp</span>
              <input type="number" class="sdems-gamble-cost-silver" value="{{cost.sp}}" min="0" title="Silver"
                placeholder="sp">
              <span>sp</span>
            </div>
            <button class="sdems-gamble-remove-btn" type="button" title="Remove">
              <i class="fas fa-xmark"></i>
            </button>
          </div>
          {{/each}}
        </div>

        {{!-- Add new option --}}
        <div class="sdems-gamble-add-row">
          <input type="text" class="sdems-gamble-new-name" placeholder="Display name…">
          <select class="sdems-gamble-new-source">
            {{#each gambleSources}}
            <option value="{{id}}">{{label}}</option>
            {{/each}}
          </select>
          <input type="number" class="sdems-gamble-new-gold" value="5" min="0" placeholder="gp cost">
          <button class="sdems-gamble-add-btn" type="button">
            <i class="fas fa-plus"></i> Add
          </button>
        </div>
      </div>

    </div>
    {{/if}}

  </div>
</div>