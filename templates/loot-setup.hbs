<div class="sde-loot-setup">
  <p class="sde-loot-setup-intro">
    Browse the loot &amp; treasure tables below. These are <strong>The Arcane Library's</strong> content, so the
    module can't ship them — <em>Unlock</em> pulls one from your own PDF through the Importer (it files into the
    tables compendium). <em>Bind</em> a Core band to its level tier so the Loot Generator can roll level-scaled
    drops automatically.
  </p>

  <div class="sde-loot-setup-progress"><i class="fas fa-list-check"></i> {{done}} of {{total}} treasure tiers bound</div>

  <div class="sde-loot-setup-library">
    {{#each library as |g|}}
    <section class="sde-loot-lib-group">
      <h4 class="sde-loot-lib-group-title">{{g.label}}</h4>
      <ul class="sde-loot-lib-entries">
        {{#each g.entries as |e|}}
        <li class="sde-loot-lib-entry {{#if e.present}}is-present{{/if}}">
          <span class="sde-loot-lib-name">
            {{e.displayName}}{{#if e.page}} <span class="sde-loot-lib-page">p.{{e.page}}</span>{{/if}}
            {{#if e.isTier}}<span class="sde-loot-lib-tier">Tier {{e.tier}}</span>{{/if}}
          </span>
          <span class="sde-loot-lib-ctrl">
            {{#if e.present}}
              {{#if e.isTier}}
                {{#if e.boundHere}}
                <span class="sde-loot-setup-badge ok"><i class="fas fa-check"></i> Bound</span>
                {{else}}
                <button type="button" class="sde-loot-setup-bind" data-action="bindLibrary" data-tier="{{e.tier}}" data-uuid="{{e.uuid}}"
                        title="Bind this table to the Levels {{e.tier}} tier">
                  <i class="fas fa-link"></i> Bind
                </button>
                {{/if}}
              {{else}}
                <span class="sde-loot-setup-badge ok"><i class="fas fa-check"></i> In library</span>
              {{/if}}
            {{else}}
            <button type="button" class="sde-loot-setup-unlock" data-action="unlockLibrary" data-name="{{e.name}}" data-src="{{e.src}}">
              <i class="fas fa-unlock"></i> Unlock
            </button>
            {{/if}}
          </span>
        </li>
        {{/each}}
      </ul>
    </section>
    {{/each}}
  </div>

  {{! ── Add any table to the Loot Generator dropdown (no tier) ── }}
  <section class="sde-loot-custom">
    <h4 class="sde-loot-lib-group-title">Loot Generator tables</h4>
    <p class="sde-loot-custom-hint">Tables you can pick and roll directly in the Loot Generator — no level tier needed.</p>
    {{#if managed.length}}
    <ul class="sde-loot-picker-list">
      {{#each managed as |m|}}
      <li class="sde-loot-picker-item">
        <span class="sde-loot-lib-name">{{m.name}} <span class="sde-loot-lib-page">{{m.group}}</span></span>
        <button type="button" class="sde-loot-setup-unlock" data-action="removePicker" data-uuid="{{m.uuid}}" title="Remove from the Loot Generator">
          <i class="fas fa-xmark"></i> Remove
        </button>
      </li>
      {{/each}}
    </ul>
    {{else}}
    <p class="sde-loot-custom-hint">None added yet.</p>
    {{/if}}
    {{#if hasAddable}}
    <div class="sde-loot-custom-row">
      <select data-picker-add aria-label="Add a table to the Loot Generator">
        <option value="">Choose a table to add…</option>
        {{#each addable as |t|}}<option value="{{t.uuid}}">{{t.name}} ({{t.group}})</option>{{/each}}
      </select>
      <button type="button" class="sde-loot-setup-bind" data-action="addPicker"><i class="fas fa-plus"></i> Add</button>
    </div>
    {{/if}}
  </section>

  {{! ── Bind any other loot table to a tier (homebrew / other books) ── }}
  <section class="sde-loot-custom">
    <h4 class="sde-loot-lib-group-title">Bind another table</h4>
    {{#if hasLootTables}}
    <div class="sde-loot-custom-row">
      <select data-custom-tier aria-label="Tier">
        {{#each tierOptions as |t|}}<option value="{{t.tier}}">{{t.label}}{{#if t.boundName}} — {{t.boundName}}{{/if}}</option>{{/each}}
      </select>
      <select data-custom-table aria-label="Loot table">
        <option value="">Choose a loot table…</option>
        {{#each lootTables as |t|}}<option value="{{t.uuid}}">{{t.name}} ({{t.group}})</option>{{/each}}
      </select>
      <button type="button" class="sde-loot-setup-bind" data-action="bindCustom"><i class="fas fa-link"></i> Bind</button>
    </div>
    {{else}}
    <p class="sde-loot-custom-hint">No loot tables yet — unlock one above first.</p>
    {{/if}}
    <p class="sde-loot-custom-hint">Don't see your table? Right-click it in the sidebar → <strong>Mark as Loot Table</strong>, then it'll appear here.</p>
  </section>
</div>
