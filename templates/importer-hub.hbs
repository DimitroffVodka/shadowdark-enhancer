<div class="sde-thub sde-importer-hub sde-hub-import" id="sde-hub-import">

  {{!-- ═══ Type selector ═══ --}}
  <div class="sde-hub-import-typebar">
    <label for="sde-hub-import-type"><i class="fas fa-filter"></i> Importing</label>
    <select id="sde-hub-import-type" data-import-type class="sde-hub-import-type-sel" aria-label="What are you importing">
      {{#each importData.typeOptions as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
    </select>
    {{#if importData.showItemSubtype}}
    <label for="sde-hub-import-subtype" class="sde-hub-import-subtype-label">item type</label>
    <select id="sde-hub-import-subtype" data-import-subtype class="sde-hub-import-type-sel" aria-label="Force item type">
      {{#each importData.itemSubtypeOptions as |o|}}<option value="{{o.value}}" {{#if o.selected}}selected{{/if}}>{{o.label}}</option>{{/each}}
    </select>
    {{/if}}
    {{#if importData.showGenSpec}}
    <label for="sde-hub-import-genspec" class="sde-hub-import-subtype-label"
           data-tooltip="How many dice and their size, e.g. 3d6 = 3 columns each rolled on a d6 (6 rows). Fixes the grid shape even for a messy or header-less paste. Leave blank to auto-detect." data-tooltip-direction="UP">dice</label>
    <input id="sde-hub-import-genspec" type="text" data-gen-spec value="{{importData.genSpec}}"
           placeholder="e.g. 3d6" class="sde-hub-import-type-sel sde-hub-import-genspec-input" aria-label="Generator dice spec (e.g. 3d6)">
    {{/if}}
  </div>

  {{!-- Seed hint: shown when a Manage-strip "Seed" click pre-filled this box --}}
  {{#if importData.seed}}
  <div class="sde-hub-import-seed">
    <i class="fas fa-bullseye"></i>
    Pasting for: <strong>{{importData.seed.name}}</strong>
    {{#if importData.seed.book}}<span class="sde-hub-import-seed-tag"><i class="fas fa-book"></i> {{importData.seed.book}}{{#if importData.seed.page}}, page {{importData.seed.page}}{{/if}}</span>{{/if}}
    {{#if importData.seed.die}}<span class="sde-hub-import-seed-tag">{{importData.seed.die}}</span>{{/if}}
    {{#if importData.seedPdfHref}}<button type="button" data-action="openSourcePdf" data-href="{{importData.seedPdfHref}}" class="sde-hub-import-pdfbtn" title="Open the source PDF at the cited page to copy from"><i class="fas fa-file-pdf"></i> Open PDF{{#if importData.seed.page}} p.{{importData.seed.page}}{{/if}}</button>{{/if}}
    {{#unless importData.seedResult}}— paste that section and click Parse.{{/unless}}
    {{#if importData.seedResult}}
    {{#if importData.seedResult.ok}}
    <span class="sde-thub-stat ok"><i class="fas fa-circle-check"></i>
      Parsed "{{importData.seedResult.name}}": {{importData.seedResult.rows}} rows on {{importData.seedResult.formula}} — correct. Review below, then Create tables.</span>
    {{else}}
    <span class="sde-thub-stat miss"><i class="fas fa-triangle-exclamation"></i>
      Parsed {{importData.seedResult.rows}} rows on {{importData.seedResult.formula}}, but "{{importData.seedResult.name}}" should be {{importData.seedResult.expected}} — check the paste for missing lines.</span>
    {{/if}}
    {{/if}}
  </div>
  {{/if}}

  {{!-- Paste box --}}
  <label class="sde-hub-import-label" for="sde-hub-import-text">
    Paste a raw dump from your Shadowdark book — monsters, items, spells, tables, or a mix:
  </label>
  <textarea id="sde-hub-import-text" data-import-text rows="6" class="sde-hub-import-text"
            placeholder="DIRE WOLF&#10;AC 12, HP 11, ATK 1 bite +3 (1d6), MV double near, S +2, D +2, C +1, I -3, W +1, Ch -2, AL N, LV 2&#10;&#10;DETECT MAGIC&#10;Tier 1, Wizard&#10;Duration: 5 rounds&#10;Range: Near&#10;You sense the presence of magic nearby.">{{importData.text}}</textarea>

  {{!-- Source label --}}
  <div class="sde-hub-import-sourcebar">
    <label for="sde-hub-import-source"><i class="fas fa-folder-tree"></i> Source</label>
    <input id="sde-hub-import-source" type="text" data-import-source list="sde-hub-import-sources"
           value="{{importData.source}}" placeholder="e.g. CS4 or Western Reaches"
           class="sde-hub-import-source-input" aria-label="Source label (folder + per-doc tag)">
    <datalist id="sde-hub-import-sources">
      {{#each importData.sourceSuggestions as |s|}}<option value="{{s}}"></option>{{/each}}
    </datalist>
  </div>

  {{!-- Controls: Parse / Clear / Import all --}}
  <div class="sde-hub-import-controls">
    <button type="button" data-action="hubParse"><i class="fas fa-wand-magic"></i> Parse</button>
    <button type="button" data-action="hubParseCompound" class="sde-import-secondary"
            title="Parse the paste as a roll-all compound generator (roll every column, combine in order). Asks for the dice, e.g. 3d6.">
      <i class="fas fa-dice-d6"></i> Compound
    </button>
    <button type="button" data-action="hubClear" class="sde-import-secondary"><i class="fas fa-eraser"></i> Clear</button>
    {{#if importData.showImportAll}}
    <button type="button" data-action="hubCommitAll" class="sde-import-primary">
      <i class="fas fa-file-import"></i> Import all
    </button>
    {{/if}}
  </div>

  <p class="sde-import-note">
    <i class="fas fa-circle-info"></i> Parsing is offline — nothing is uploaded.
    Auto-detect sorts a mixed dump; pick a specific type to force it. Fields the parser
    wasn't sure about are <span class="sde-mimport-warn-legend">highlighted</span>.
  </p>

  {{!-- Bundle row: suite-wide export / import --}}
  <div class="sde-hub-import-controls sde-hub-bundle-row">
    <button type="button" data-action="hubExportBundle" class="sde-import-secondary"
            title="Download all imported content (every Shadowdark Enhancer compendium pack) as one JSON bundle.">
      <i class="fas fa-file-export"></i> Export bundle
    </button>
    <button type="button" data-action="hubImportBundle" class="sde-import-secondary"
            title="Import a bundle file into this world's compendium packs. Existing documents are never overwritten.">
      <i class="fas fa-file-arrow-up"></i> Import bundle
    </button>
    <button type="button" data-action="hubManageSourcePdfs" class="sde-import-secondary"
            title="Upload your own PDFs of the Shadowdark books. Each is linked to a source so the Open-PDF buttons jump to the cited page. Files stay in your world.">
      <i class="fas fa-file-pdf"></i> Source PDFs
    </button>
  </div>

  {{!-- ── Monsters preview ─────────────────────────────────────────────── --}}
  {{#if importData.hasMonsters}}
  <section class="sde-hub-import-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle"><i class="fas fa-dragon"></i> Monsters ({{importData.monstersCount}})</span>
      <button type="button" data-action="hubCommitMonsters" class="sde-import-primary sde-hub-import-secbtn">
        <i class="fas fa-dragon"></i> Create monsters
      </button>
    </div>
    <p class="sde-hub-import-srcnote">
      <i class="fas fa-folder-tree"></i> Filing as: <strong>{{#if importData.source}}{{importData.source}}{{else}}(no source){{/if}}</strong>
    </p>
    <div class="sde-import-preview">
      {{#each importData.monsters as |m|}}
      <div class="sde-mimport-card" data-monster-idx="{{m.idx}}">
        <div class="sde-mimport-card-head">
          <input type="text" data-mimport-field="name" value="{{m.draft.name}}"
                 class="sde-import-name sde-mimport-cardname" aria-label="Monster name" placeholder="Monster name">
          {{#if m.hasWarnings}}
          <span class="sde-mimport-warncount" title="Parser flagged {{m.warnCount}} field(s) for review">
            <i class="fas fa-triangle-exclamation"></i> {{m.warnCount}}
          </span>
          {{/if}}
          <button type="button" data-action="mimportRemoveMonster" class="sde-import-del"
                  aria-label="Remove this monster" title="Don't import this one"><i class="fas fa-xmark"></i></button>
        </div>
        {{#if m.hasWarnings}}
        <ul class="sde-import-warnings">{{#each m.warnings as |w|}}<li>{{w}}</li>{{/each}}</ul>
        {{/if}}
        <div class="sde-mimport-stats">
          <label>LV <input type="number" data-mimport-field="level" value="{{m.draft.level}}" class="sde-import-num{{#if m.warn.level}} sde-mimport-warn{{/if}}"></label>
          <label>AC <input type="number" data-mimport-field="ac" value="{{m.draft.ac}}" class="sde-import-num{{#if m.warn.ac}} sde-mimport-warn{{/if}}"></label>
          <label>HP <input type="number" data-mimport-field="hpValue" value="{{m.draft.hp.value}}" class="sde-import-num{{#if m.warn.hp}} sde-mimport-warn{{/if}}"></label>
          <label class="sde-mimport-hpmax">/ <input type="number" data-mimport-field="hpMax" value="{{m.draft.hp.max}}" class="sde-import-num{{#if m.warn.hp}} sde-mimport-warn{{/if}}" aria-label="HP max"></label>
          <label>AL
            <select data-mimport-field="alignment" class="sde-mimport-sel{{#if m.warn.alignment}} sde-mimport-warn{{/if}}">
              {{#each @root.importData.alignments as |a|}}<option value="{{a}}" {{#if (eq a m.draft.alignment)}}selected{{/if}}>{{a}}</option>{{/each}}
            </select>
          </label>
          <label>MV
            <select data-mimport-field="move" class="sde-mimport-sel{{#if m.warn.move}} sde-mimport-warn{{/if}}">
              {{#each @root.importData.moveOptions as |mv|}}<option value="{{mv}}" {{#if (eq mv m.draft.move)}}selected{{/if}}>{{mv}}</option>{{/each}}
            </select>
          </label>
          <input type="text" data-mimport-field="moveNote" value="{{m.draft.moveNote}}" class="sde-mimport-movenote" placeholder="move note (climb, swim…)" aria-label="Movement note">
        </div>
        <div class="sde-mimport-abils{{#if m.warn.abilities}} sde-mimport-warn-row{{/if}}">
          {{#each @root.importData.abilityKeys as |ab|}}
          <label>{{ab.label}} <input type="number" data-mimport-field="{{ab.key}}" value="{{lookup m.draft.abilities ab.key}}" class="sde-import-num"></label>
          {{/each}}
        </div>
        <div class="sde-mimport-spell{{#if m.warn.spellcasting}} sde-mimport-warn-row{{/if}}">
          <span class="sde-mimport-sublabel">Spellcasting</span>
          <label>ability
            <select data-mimport-field="scAbility" class="sde-mimport-sel">
              {{#each @root.importData.spellAbilities as |sa|}}<option value="{{sa.value}}" {{#if (eq sa.value m.draft.spellcasting.ability)}}selected{{/if}}>{{sa.label}}</option>{{/each}}
            </select>
          </label>
          <label>bonus <input type="number" data-mimport-field="scBonus" value="{{m.draft.spellcasting.bonus}}" class="sde-import-num"></label>
          <label>spells/rd <input type="number" data-mimport-field="scAttacks" value="{{m.draft.spellcasting.attacks}}" class="sde-import-num"></label>
        </div>
        <div class="sde-mimport-section{{#if m.warn.attacks}} sde-mimport-warn-row{{/if}}">
          <div class="sde-mimport-sechead">
            <span class="sde-mimport-sublabel">Attacks</span>
            <button type="button" data-action="mimportAddAttack" class="sde-import-addrow"><i class="fas fa-plus"></i> Attack</button>
            <button type="button" data-action="mimportAddSpecial" class="sde-import-addrow"><i class="fas fa-plus"></i> Special</button>
          </div>
          {{#each m.draft.actions as |a|}}
          <div class="sde-mimport-attack" data-attack-idx="{{@index}}">
            <input type="number" data-mimport-field="aNum" value="{{a.num}}" class="sde-import-num" aria-label="Attacks per round" title="count">
            <input type="text" data-mimport-field="aName" value="{{a.name}}" class="sde-mimport-aname" aria-label="Attack name" placeholder="name">
            <select data-mimport-field="aType" class="sde-mimport-sel" aria-label="Attack type">
              {{#each @root.importData.attackTypes as |ty|}}<option value="{{ty}}" {{#if (eq ty a.type)}}selected{{/if}}>{{ty}}</option>{{/each}}
            </select>
            <input type="number" data-mimport-field="aBonus" value="{{a.bonus}}" class="sde-import-num" aria-label="To-hit bonus" title="+hit">
            <input type="text" data-mimport-field="aDamage" value="{{a.damage}}" class="sde-mimport-dmg" aria-label="Damage" placeholder="1d6">
            <input type="text" data-mimport-field="aRanges" value="{{join a.ranges}}" class="sde-mimport-ranges" aria-label="Ranges" placeholder="close, near">
            <input type="text" data-mimport-field="aDesc" value="{{a.description}}" class="sde-import-rowtext" aria-label="Rider / effect" placeholder="rider (swallow…)">
            <button type="button" data-action="mimportRemoveAttack" class="sde-import-del" aria-label="Remove attack"><i class="fas fa-xmark"></i></button>
          </div>
          {{/each}}
        </div>
        <div class="sde-mimport-section">
          <div class="sde-mimport-sechead">
            <span class="sde-mimport-sublabel">Features</span>
            <button type="button" data-action="mimportAddFeature" class="sde-import-addrow"><i class="fas fa-plus"></i> Feature</button>
          </div>
          {{#each m.draft.features as |f|}}
          <div class="sde-mimport-feature" data-feature-idx="{{@index}}">
            <input type="text" data-mimport-field="fName" value="{{f.name}}" class="sde-mimport-fname" aria-label="Feature name" placeholder="name">
            <input type="text" data-mimport-field="fDesc" value="{{f.description}}" class="sde-import-rowtext" aria-label="Feature text" placeholder="description">
            <button type="button" data-action="mimportRemoveFeature" class="sde-import-del" aria-label="Remove feature"><i class="fas fa-xmark"></i></button>
          </div>
          {{/each}}
        </div>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ── Items preview ────────────────────────────────────────────────── --}}
  {{#if importData.hasItems}}
  <section class="sde-hub-import-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle"><i class="fas fa-gem"></i> Items ({{importData.itemsCount}})</span>
      <button type="button" data-action="hubCommitItems" class="sde-import-primary sde-hub-import-secbtn">
        <i class="fas fa-gem"></i> Create items
      </button>
    </div>
    <div class="sde-import-preview">
      {{#each importData.items as |it|}}
      <div class="sde-hub-import-item-card" data-item-idx="{{@index}}">
        <div class="sde-hub-import-item-head">
          <input type="text" data-iimport-field="name" value="{{it.draft.name}}"
                 class="sde-import-name sde-hub-import-item-name" aria-label="Item name" placeholder="Item name">
          <select data-iimport-field="type" class="sde-hub-import-item-type sde-mimport-sel" aria-label="Item type">
            {{#each @root.importData.itemTypeOptions as |opt|}}
            <option value="{{opt}}" {{#if (eq opt it.draft.type)}}selected{{/if}}>{{opt}}</option>
            {{/each}}
          </select>
          <button type="button" data-action="iimportRemoveItem" class="sde-import-del"
                  aria-label="Remove this item" title="Don't import this one"><i class="fas fa-xmark"></i></button>
        </div>
        <div class="sde-hub-import-item-fields">
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">gp</span>
            <input type="number" data-iimport-field="costGp" value="{{it.draft.cost.gp}}" class="sde-import-num" aria-label="Cost gp"></label>
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">sp</span>
            <input type="number" data-iimport-field="costSp" value="{{it.draft.cost.sp}}" class="sde-import-num" aria-label="Cost sp"></label>
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">cp</span>
            <input type="number" data-iimport-field="costCp" value="{{it.draft.cost.cp}}" class="sde-import-num" aria-label="Cost cp"></label>
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">slots</span>
            <input type="number" data-iimport-field="slots" value="{{it.draft.slots.slots_used}}" class="sde-import-num" aria-label="Slots used"></label>
        </div>
        <div class="sde-hub-import-item-desc">
          <input type="text" data-iimport-field="description" value="{{it.draft.description}}"
                 class="sde-hub-import-item-desc-input" aria-label="Item description" placeholder="Description">
        </div>
        {{#if it.warnings.length}}
        <ul class="sde-import-warnings">{{#each it.warnings as |w|}}<li>{{w}}</li>{{/each}}</ul>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ── Spells preview ───────────────────────────────────────────────── --}}
  {{#if importData.hasSpells}}
  <section class="sde-hub-import-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle"><i class="fas fa-wand-sparkles"></i> Spells ({{importData.spellsCount}})</span>
      <button type="button" data-action="hubCommitSpells" class="sde-import-primary sde-hub-import-secbtn">
        <i class="fas fa-wand-sparkles"></i> Create spells
      </button>
    </div>
    <div class="sde-import-preview">
      {{#each importData.spells as |sp|}}
      <div class="sde-hub-import-item-card" data-spell-idx="{{sp.idx}}">
        <div class="sde-hub-import-item-head">
          <input type="text" data-simport-field="name" value="{{sp.draft.name}}"
                 class="sde-import-name sde-hub-import-item-name" aria-label="Spell name" placeholder="Spell name">
          {{#if sp.hasWarnings}}
          <span class="sde-mimport-warncount" title="Parser flagged {{sp.warnCount}} field(s)"><i class="fas fa-triangle-exclamation"></i> {{sp.warnCount}}</span>
          {{/if}}
          <button type="button" data-action="simportRemoveSpell" class="sde-import-del"
                  aria-label="Remove this spell" title="Don't import this one"><i class="fas fa-xmark"></i></button>
        </div>
        <div class="sde-hub-import-item-fields">
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">Tier</span>
            <input type="number" min="1" max="5" data-simport-field="tier" value="{{sp.draft.tier}}" class="sde-import-num" aria-label="Spell tier"></label>
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">Class</span>
            <input type="text" data-simport-field="className" value="{{sp.draft.className}}" class="sde-mimport-aname" aria-label="Class name" placeholder="Wizard"></label>
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">Range</span>
            <select data-simport-field="range" class="sde-mimport-sel" aria-label="Range">
              {{#each @root.importData.spellRanges as |rg|}}<option value="{{rg}}" {{#if (eq rg sp.draft.range)}}selected{{/if}}>{{rg}}</option>{{/each}}
            </select></label>
          <label class="sde-hub-import-item-field"><span class="sde-hub-import-item-label">Duration</span>
            <select data-simport-field="durationType" class="sde-mimport-sel" aria-label="Duration type">
              {{#each @root.importData.spellDurationTypes as |dt|}}<option value="{{dt}}" {{#if (eq dt sp.draft.duration.type)}}selected{{/if}}>{{dt}}</option>{{/each}}
            </select>
            <input type="text" data-simport-field="durationValue" value="{{sp.draft.duration.value}}" class="sde-import-num" aria-label="Duration value" title="rounds/days; -1 = n/a"></label>
        </div>
        <div class="sde-hub-import-item-desc">
          <input type="text" data-simport-field="description" value="{{sp.draft.description}}"
                 class="sde-hub-import-item-desc-input" aria-label="Spell description" placeholder="Description">
        </div>
        {{#if sp.warnings.length}}
        <ul class="sde-import-warnings">{{#each sp.warnings as |w|}}<li>{{w}}</li>{{/each}}</ul>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ── Character content / sealed-unlock preview ─────────────────────── --}}
  {{!-- Title + button label come from context: sealed payloads may be roll
        tables or monsters, which commit to their own compendia, not Items. --}}
  {{#if importData.hasChar}}
  <section class="sde-hub-import-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle"><i class="fas fa-user-plus"></i> {{importData.charsTitle}} ({{importData.charsCount}})</span>
      <button type="button" data-action="hubCommitChar" class="sde-import-primary sde-hub-import-secbtn">
        <i class="fas fa-unlock"></i> {{importData.charsCommitLabel}}
      </button>
    </div>
    <div class="sde-import-preview">
      {{#each importData.chars as |c|}}
      <div class="sde-hub-import-item-card">
        <div class="sde-hub-import-item-head">
          <span class="sde-hub-import-item-name">{{c.name}}</span>
          <span class="sde-hub-monsters-dup-source">{{c.type}}</span>
        </div>
        {{#if c.unit}}
        {{!-- Full class-unit preview: everything the commit will author. --}}
        <div class="sde-class-preview" data-char-idx="{{@index}}">
          <div class="sde-cusheet-head">{{c.name}}</div>
          <div class="sde-cusheet-details">
            <label class="sde-cusheet-field">
              <span class="sde-cusheet-fieldname">HP Die Roll</span>
              <input type="text" data-cu-field="hp" value="{{c.unit.hp}}" aria-label="Hit die">
            </label>
            <label class="sde-cusheet-field">
              <span class="sde-cusheet-fieldname">Spellcasting Ability</span>
              <select data-cu-field="scAbility" aria-label="Spellcasting ability">
                {{#each c.unit.scOptions as |o|}}<option value="{{o.value}}"{{#if o.selected}} selected{{/if}}>{{o.label}}</option>{{/each}}
              </select>
            </label>
            {{#if c.unit.isCaster}}
            <label class="sde-cusheet-field" title="Which spell list this class casts from — pick an existing caster (Knight of St. Ydris uses Witch) or keep its own new list">
              <span class="sde-cusheet-fieldname">Spell List</span>
              <select data-cu-field="spellList" aria-label="Spell list">
                {{#each c.unit.spellListOptions as |o|}}<option value="{{o.value}}"{{#if o.selected}} selected{{/if}}>{{o.label}}</option>{{/each}}
              </select>
            </label>
            {{/if}}
          </div>

          <details class="sde-class-preview-block" open>
            <summary>Description</summary>
            <textarea data-cu-field="flavor" rows="2" class="sde-cu-area" aria-label="Class description / flavor">{{c.unit.flavor}}</textarea>
          </details>

          <details class="sde-class-preview-block" open>
            <summary>Equipment</summary>
            <div class="sde-cusheet-cols">
              <div class="sde-cusheet-box">
                <h5>Weapons</h5>
                <input type="text" data-cu-field="weapons" value="{{c.unit.weaponsText}}" class="sde-cu-text" placeholder="Type here…" title="Named weapons; combine with the All checkboxes for grants like “All melee weapons, crossbow”">
              </div>
              <div class="sde-cusheet-box">
                <h5>Armor</h5>
                <input type="text" data-cu-field="armor" value="{{c.unit.armorText}}" class="sde-cu-text" placeholder="Type here…" title="Named armor; combines with the All armor checkbox">
              </div>
              <div class="sde-cusheet-box">
                <h5>Options</h5>
                <label class="sde-cusheet-check">All Weapons <input type="checkbox" data-cu-field="allWeapons" {{#if c.unit.allWeapons}}checked{{/if}}></label>
                <label class="sde-cusheet-check">All Melee Weapons <input type="checkbox" data-cu-field="allMeleeWeapons" {{#if c.unit.allMeleeWeapons}}checked{{/if}}></label>
                <label class="sde-cusheet-check">All Ranged Weapons <input type="checkbox" data-cu-field="allRangedWeapons" {{#if c.unit.allRangedWeapons}}checked{{/if}}></label>
                <label class="sde-cusheet-check">All Armor <input type="checkbox" data-cu-field="allArmor" {{#if c.unit.allArmor}}checked{{/if}}></label>
              </div>
            </div>
          </details>

          <details class="sde-class-preview-block" open>
            <summary>Languages</summary>
            <div class="sde-cusheet-cols">
              <div class="sde-cusheet-box">
                <h5>Fixed</h5>
                <input type="text" data-cu-field="langFixed" value="{{c.unit.langFixed}}" class="sde-cu-text" placeholder="Type here…">
              </div>
              <div class="sde-cusheet-box">
                <h5>Options</h5>
                <label class="sde-cusheet-check">Additional Common <input type="number" min="0" data-cu-field="langCommon" value="{{c.unit.langCommon}}" class="sde-cu-num" aria-label="Additional common languages"></label>
                <label class="sde-cusheet-check">Additional Rare <input type="number" min="0" data-cu-field="langRare" value="{{c.unit.langRare}}" class="sde-cu-num" aria-label="Additional rare languages"></label>
              </div>
            </div>
          </details>

          <details class="sde-class-preview-block" open>
            <summary>Class Features ({{c.unit.features.length}})</summary>
            <div class="sde-cu-features">
              {{#each c.unit.features as |f|}}
              <div class="sde-cu-featrow" data-cu-feat="{{@index}}">
                <input type="text" data-cu-field="featName" value="{{f.name}}" class="sde-cu-featname" aria-label="Feature name">
                <input type="text" data-cu-field="featText" value="{{f.text}}" class="sde-cu-text" aria-label="Feature rules text">
                <button type="button" data-action="cuFeatDel" class="sde-cu-btn sde-cu-btn-del" title="Remove this feature"><i class="fas fa-trash"></i></button>
              </div>
              {{/each}}
              <button type="button" data-action="cuFeatAdd" class="sde-cu-btn" title="Add a feature"><i class="fas fa-plus"></i> feature</button>
            </div>
          </details>

          <details class="sde-class-preview-block" open>
            <summary>Talent table{{#if c.unit.table}} ({{c.unit.table.formula}}){{else}} — none found{{/if}}</summary>
            {{#unless c.unit.table}}
            <p class="sde-class-preview-flavor">No table parsed from the paste — add rows below to build one (2d6 by default).</p>
            {{/unless}}
            {{#if c.unit.table}}
            <table class="sde-class-preview-table">
              {{#each c.unit.table.rows as |r|}}
              <tr data-cu-row="{{@index}}">
                <td class="sde-class-preview-range">
                  <input type="text" data-cu-field="range" value="{{r.range}}" class="sde-cu-range" aria-label="Roll range" title='e.g. "2" or "3-6"'>
                </td>
                <td>
                  <input type="text" data-cu-field="text" value="{{r.text}}" class="sde-cu-text" aria-label="Effect text">
                  {{#if r.isChoice}}
                  <div class="sde-class-preview-opts">
                    {{#each r.options as |o|}}
                    <span class="sde-cu-optwrap" data-cu-opt="{{@index}}">
                      <input type="text" data-cu-field="option" value="{{o}}" class="sde-cu-opt" aria-label="Choice option">
                      <button type="button" data-action="cuOptDel" class="sde-cu-btn sde-cu-btn-del" title="Remove this option"><i class="fas fa-xmark"></i></button>
                    </span>
                    {{/each}}
                    <button type="button" data-action="cuOptAdd" class="sde-cu-btn" title="Add an option"><i class="fas fa-plus"></i> option</button>
                    <button type="button" data-action="cuRowMerge" class="sde-cu-btn" title="Drop the options — this row becomes one talent named by its effect text">merge to single</button>
                  </div>
                  {{else if r.grand}}
                  <div class="sde-class-preview-opts"><span class="sde-class-opt sde-class-opt-grand">links every option above + Distribute to Stats</span></div>
                  {{else}}
                  <div class="sde-class-preview-opts">
                    <button type="button" data-action="cuRowSplit" class="sde-cu-btn" title="This row is a pick — split the text into options">split into options</button>
                  </div>
                  {{/if}}
                </td>
                <td class="sde-cu-rowdel">
                  <button type="button" data-action="cuRowDel" class="sde-cu-btn sde-cu-btn-del" title="Delete this row"><i class="fas fa-trash"></i></button>
                </td>
              </tr>
              {{/each}}
            </table>
            {{/if}}
            <div class="sde-class-preview-opts sde-cu-addrow">
              <button type="button" data-action="cuRowAdd" class="sde-cu-btn" title="Add a row"><i class="fas fa-plus"></i> row</button>
              {{#if c.unit.table}}
              <label class="sde-cu-formula">formula <input type="text" data-cu-field="tblFormula" value="{{c.unit.table.formula}}" class="sde-cu-num" aria-label="Table roll formula"></label>
              {{/if}}
            </div>
          </details>

          {{#if c.unit.isCaster}}
          <details class="sde-class-preview-block" open>
            <summary>Spellcasting</summary>
            <textarea data-cu-field="scText" rows="2" class="sde-cu-area" aria-label="Spellcasting rules text">{{c.unit.scText}}</textarea>
            {{#if c.unit.spellsKnown.length}}
            <div class="sde-cu-spellsknown" title="Spells known per level (tier 1 · 2 · 3 · …) — parsed from the SPELLS KNOWN table; commits to the class sheet's grid">
              {{#each c.unit.spellsKnown as |r|}}<span class="sde-class-opt">Lv {{r.level}}: {{r.cells}}</span>{{/each}}
            </div>
            {{/if}}
          </details>
          {{/if}}

          <details class="sde-class-preview-block" open>
            <summary>Titles ({{c.unit.titles.length}})</summary>
            <table class="sde-class-preview-table sde-cu-titles">
              {{#if c.unit.titles.length}}
              <tr class="sde-cu-titlehead"><th>Levels</th><th>Lawful</th><th>Chaotic</th><th>Neutral</th><th></th></tr>
              {{/if}}
              {{#each c.unit.titles as |t|}}
              <tr data-cu-title="{{@index}}">
                <td class="sde-class-preview-range"><input type="text" data-cu-field="titleRange" value="{{t.range}}" class="sde-cu-range" aria-label="Level range"></td>
                <td><input type="text" data-cu-field="titleLawful" value="{{t.lawful}}" class="sde-cu-text" aria-label="Lawful title"></td>
                <td><input type="text" data-cu-field="titleChaotic" value="{{t.chaotic}}" class="sde-cu-text" aria-label="Chaotic title"></td>
                <td><input type="text" data-cu-field="titleNeutral" value="{{t.neutral}}" class="sde-cu-text" aria-label="Neutral title"></td>
                <td class="sde-cu-rowdel"><button type="button" data-action="cuTitleDel" class="sde-cu-btn sde-cu-btn-del" title="Delete this band"><i class="fas fa-trash"></i></button></td>
              </tr>
              {{/each}}
            </table>
            <button type="button" data-action="cuTitleAdd" class="sde-cu-btn sde-cu-addrow" title="Add a title band"><i class="fas fa-plus"></i> band</button>
          </details>

          {{#if c.unit.warnings.length}}
          <details class="sde-class-preview-block sde-class-preview-notes" open>
            <summary>Review notes ({{c.unit.warnings.length}})</summary>
            <ul class="sde-import-warnings">
              {{#each c.unit.warnings as |w|}}<li>{{w}}</li>{{/each}}
            </ul>
          </details>
          {{/if}}
        </div>
        {{else}}
        <div class="sde-hub-import-item-desc">{{c.preview}}</div>
        {{/if}}
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ── Tables preview ───────────────────────────────────────────────── --}}
  {{#if importData.hasTables}}
  <section class="sde-hub-import-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle"><i class="fas fa-table-list"></i> Tables ({{importData.tablesCount}})</span>
      <button type="button" data-action="hubCommitTables" class="sde-import-primary sde-hub-import-secbtn">
        <i class="fas fa-table-list"></i> Create tables
      </button>
    </div>
    <div class="sde-import-preview">
      {{#each importData.tables as |tbl|}}
      <div class="sde-import-table" data-table-idx="{{@index}}">
        <div class="sde-import-table-head">
          <input type="text" data-import-field="name" value="{{tbl.name}}" aria-label="Table name" placeholder="Table name" class="sde-import-name">
          <input type="text" data-import-field="formula" value="{{tbl.formula}}" aria-label="Formula" class="sde-import-formula">
          <label class="sde-import-repl" data-tooltip="On: results can repeat. Off: each result is removed after drawn." data-tooltip-direction="UP">
            <input type="checkbox" data-import-field="replacement" {{#if tbl.replacement}}checked{{/if}}> Replacement
          </label>
          <label class="sde-import-repl" data-tooltip="Folder this table is filed under." data-tooltip-direction="UP"><i class="fas fa-folder"></i> Folder</label>
          <select data-import-field="category" class="sde-import-cat" aria-label="Folder this table is filed under" data-tooltip="Folder this table is filed under." data-tooltip-direction="UP">
            {{#each @root.importData.categoryOptions as |opt|}}
            <option value="{{opt.id}}" {{#if (eq opt.id tbl.category)}}selected{{/if}}>{{opt.label}}</option>
            {{/each}}
          </select>
          {{#if (eq tbl.category "custom")}}
          <input type="text" data-import-field="customLabel" value="{{tbl.customLabel}}" class="sde-import-customcat" aria-label="Custom folder name" placeholder="Folder name">
          {{/if}}
          <button type="button" data-action="hubCommitTables" class="sde-import-primary"><i class="fas fa-plus"></i> Create</button>
        </div>
        {{#if tbl.bestEffort}}
        <p class="sde-import-flag"><i class="fas fa-triangle-exclamation"></i> Best-effort column split — check the cells.</p>
        {{/if}}
        {{#if tbl.warnings.length}}
        <ul class="sde-import-warnings">{{#each tbl.warnings as |w|}}<li>{{w}}</li>{{/each}}</ul>
        {{/if}}
        <div class="sde-import-rows">
          {{#each tbl.rows as |row|}}
          <div class="sde-import-row" data-row-idx="{{@index}}">
            <input type="number" data-import-field="min" value="{{row.min}}" aria-label="Range min" class="sde-import-num">
            <span class="sde-import-dash">–</span>
            <input type="number" data-import-field="max" value="{{row.max}}" aria-label="Range max" class="sde-import-num">
            <input type="text" data-import-field="text" value="{{row.text}}" aria-label="Result text" class="sde-import-rowtext">
            {{#if row.link}}
            <span class="sde-import-link" data-tooltip="Draws as a link to this compendium item"><i class="fas fa-link"></i> {{row.link.name}}</span>
            <button type="button" data-action="importUnlinkRow" aria-label="Unlink item" class="sde-import-unlink"><i class="fas fa-link-slash"></i></button>
            {{/if}}
            <button type="button" data-action="importDeleteRow" aria-label="Delete row" class="sde-import-del"><i class="fas fa-xmark"></i></button>
          </div>
          {{/each}}
        </div>
        <button type="button" data-action="importAddRow" class="sde-import-addrow"><i class="fas fa-plus"></i> Add row</button>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ── Generators preview (roll-all compound tables) ────────────────── --}}
  {{#if importData.hasGenerators}}
  <section class="sde-hub-import-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle"><i class="fas fa-dice-d6"></i> Generators ({{importData.generatorsCount}})</span>
      <button type="button" data-action="hubCommitGenerators" class="sde-import-primary sde-hub-import-secbtn">
        <i class="fas fa-dice-d6"></i> Create generators
      </button>
    </div>
    <p class="sde-import-note">
      <i class="fas fa-circle-info"></i> A generator rolls <strong>every column once</strong> and joins the
      cells in order. Each grid row is a die face; each column is rolled independently. Fix any flagged
      cells below, then Create — roll it from the table sheet or Roll Tables directory.
    </p>
    <div class="sde-import-preview">
      {{#each importData.generators as |gen|}}
      <div class="sde-import-gen" data-gen-idx="{{gen.idx}}">
        <div class="sde-import-gen-head">
          <input type="text" data-gen-field="name" value="{{gen.name}}" aria-label="Generator name" placeholder="Generator name" class="sde-import-name">
          <label class="sde-import-repl" data-tooltip="Die each column is rolled on." data-tooltip-direction="UP">
            <i class="fas fa-dice"></i> <input type="text" data-gen-field="formula" value="{{gen.formula}}" aria-label="Formula" class="sde-import-formula">
          </label>
          <label class="sde-import-repl" data-tooltip="Text placed between column results when combined." data-tooltip-direction="UP">
            join <input type="text" data-gen-field="separator" value="{{gen.separator}}" aria-label="Separator" class="sde-import-gen-sep">
          </label>
          <button type="button" data-action="hubCommitGenerators" class="sde-import-primary"><i class="fas fa-plus"></i> Create</button>
        </div>
        {{#if gen.hasWarnings}}
        <ul class="sde-import-warnings">{{#each gen.warnings as |w|}}<li>{{w}}</li>{{/each}}</ul>
        {{/if}}
        <div class="sde-import-gen-gridwrap">
          <table class="sde-import-gen-grid">
            <thead>
              <tr>
                <th class="sde-import-gen-facehead">d</th>
                {{#each gen.columns as |col|}}
                <th data-col-idx="{{col.idx}}">
                  <input type="text" data-gen-field="label" data-col-idx="{{col.idx}}" value="{{col.label}}" aria-label="Column label" placeholder="Column {{col.idx}}" class="sde-import-gen-label">
                  <button type="button" data-action="genRemoveColumn" class="sde-import-del" aria-label="Remove column" title="Remove this column"><i class="fas fa-xmark"></i></button>
                </th>
                {{/each}}
                <th class="sde-import-gen-addcolcell">
                  <button type="button" data-action="genAddColumn" class="sde-import-addrow" aria-label="Add column" title="Add a column"><i class="fas fa-plus"></i></button>
                </th>
              </tr>
            </thead>
            <tbody>
              {{#each gen.faces as |frow|}}
              <tr data-face-row="{{frow.face}}">
                <td class="sde-import-gen-face">{{frow.face}}</td>
                {{#each frow.cells as |cell|}}
                <td>
                  <input type="text" data-gen-field="cell" data-col-idx="{{cell.colIdx}}" data-face="{{frow.face}}" value="{{cell.text}}" aria-label="Cell" class="sde-import-gen-cell">
                </td>
                {{/each}}
                <td class="sde-import-gen-rowdel">
                  <button type="button" data-action="genDeleteRow" class="sde-import-del" aria-label="Delete row" title="Delete this die face"><i class="fas fa-xmark"></i></button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
        <button type="button" data-action="genAddRow" class="sde-import-addrow"><i class="fas fa-plus"></i> Add die face</button>
      </div>
      {{/each}}
    </div>
  </section>
  {{/if}}

  {{!-- ── Skipped (always visible — nothing silently dropped) ──────────── --}}
  {{#if importData.skippedCount}}
  <section class="sde-hub-import-section sde-hub-import-skipped-section">
    <div class="sde-hub-import-sechead">
      <span class="sde-hub-import-sectitle sde-hub-import-sectitle-skipped">
        <i class="fas fa-filter-circle-xmark"></i> Skipped ({{importData.skippedCount}})
      </span>
    </div>
    <ul class="sde-hub-import-skipped-list">
      {{#each importData.skipped as |s|}}<li><strong>{{s.name}}</strong> — {{s.reason}}</li>{{/each}}
    </ul>
  </section>
  {{/if}}

  {{!-- ═══ Manage / cleanup (collapsible, lazy) ═══ --}}
  <details class="sde-hub-manage" data-manage{{#if manageExpanded}} open{{/if}}>
    <summary class="sde-hub-manage-summary">
      <i class="fas fa-screwdriver-wrench"></i> Manage
      <span class="sde-hub-manage-hint">unlocked · locked · duplicates · maintenance</span>
    </summary>

    {{#if manage}}
    <div class="sde-hub-manage-body">

      {{!-- Unlock/lock review tree: Character Content · Spells · Monsters · Items --}}
      <section class="sde-mtree">
        <div class="sde-mtree-topbar">
          <p class="sde-hub-manage-hint sde-mtree-legend">
            <i class="fas fa-lock-open"></i> unlocked = present ·
            <i class="fas fa-lock"></i> locked = importable. <strong>Unlock</strong> seeds the paste box.
          </p>
          <div class="sde-mtree-tools">
            <button type="button" class="sde-mtree-toolbtn" data-action="manageExpandAll" title="Expand every folder">
              <i class="fas fa-angles-down"></i> Expand all
            </button>
            <button type="button" class="sde-mtree-toolbtn" data-action="manageCollapseAll" title="Collapse everything">
              <i class="fas fa-angles-up"></i> Collapse all
            </button>
          </div>
        </div>
        {{#each manage.tree as |node|}}
          {{> sdeTreeNode node=node}}
        {{/each}}
      </section>

      {{!-- Monster duplicates (dedup is separate from the census tree) --}}
      {{#if manage.monstersData.hasDuplicates}}
      <section class="sde-hub-monsters-dups">
        <h3 class="sde-hub-monsters-section-title"><i class="fas fa-copy"></i> Monster duplicates ({{manage.monstersData.duplicateCount}})</h3>
        <div class="sde-hub-monsters-dup-cards">
          {{#each manage.monstersData.duplicateGroups as |group|}}
          <div class="sde-hub-monsters-dup-card" data-group-key="{{group.key}}">
            <p class="sde-hub-monsters-dup-name">{{group.key}}</p>
            <ul class="sde-hub-monsters-dup-members">
              {{#each group.members as |m|}}
              <li class="sde-hub-monsters-dup-member">
                <label class="sde-hub-monsters-dup-label">
                  <input type="radio" name="keep-{{@../index}}" value="{{m.uuid}}" {{#if @first}}checked{{/if}}>
                  <span class="sde-hub-monsters-dup-member-name">{{m.name}}</span>
                  <span class="sde-hub-monsters-dup-member-meta">
                    {{#if m.source}}<span class="sde-hub-monsters-dup-source">{{m.source}}</span>{{/if}}
                    {{#if m.date}}<span class="sde-hub-monsters-dup-date" title="Last modified">{{m.date}}</span>{{/if}}
                  </span>
                </label>
              </li>
              {{/each}}
            </ul>
            <button type="button" class="sde-hub-monsters-cull-btn" data-action="monsterCullGroup" data-group-key="{{group.key}}">
              <i class="fas fa-trash-can"></i> Cull others
            </button>
          </div>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{!-- Item duplicates (dedup is separate from the census tree) --}}
      {{#if manage.itemsData.hasDuplicates}}
      <section class="sde-hub-monsters-dups">
        <h3 class="sde-hub-monsters-section-title"><i class="fas fa-copy"></i> Item duplicates ({{manage.itemsData.duplicateCount}})</h3>
        <div class="sde-hub-monsters-dup-cards">
          {{#each manage.itemsData.duplicateGroups as |group|}}
          <div class="sde-hub-monsters-dup-card" data-group-key="{{group.key}}">
            <p class="sde-hub-monsters-dup-name">{{group.key}}</p>
            <ul class="sde-hub-monsters-dup-members">
              {{#each group.members as |m|}}
              <li class="sde-hub-monsters-dup-member">
                <label class="sde-hub-monsters-dup-label">
                  <input type="radio" name="keep-item-{{@../index}}" value="{{m.uuid}}" {{#if @first}}checked{{/if}}>
                  <span class="sde-hub-monsters-dup-member-name">{{m.name}}</span>
                  <span class="sde-hub-monsters-dup-member-meta">
                    {{#if m.source}}<span class="sde-hub-monsters-dup-source">{{m.source}}</span>{{/if}}
                    {{#if m.date}}<span class="sde-hub-monsters-dup-date" title="Last modified">{{m.date}}</span>{{/if}}
                  </span>
                </label>
              </li>
              {{/each}}
            </ul>
            <button type="button" class="sde-hub-monsters-cull-btn" data-action="itemCullGroup" data-group-key="{{group.key}}">
              <i class="fas fa-trash-can"></i> Cull others
            </button>
          </div>
          {{/each}}
        </div>
      </section>
      {{/if}}

      {{!-- Maintenance actions --}}
      <section class="sde-hub-monsters-maintenance">
        <h3 class="sde-hub-monsters-section-title"><i class="fas fa-wrench"></i> Maintenance</h3>
        <div class="sde-hub-monsters-maintenance-row">
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="hubRelinkTables"
                  title="Re-link every compendium table to your imported monsters and items. Safe to re-run.">
            <i class="fas fa-link"></i> Re-link pack tables
          </button>
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="migrateCompendium"
                  title="Copy module-imported world tables into the sde-tables compendium pack (originals → _Backup).">
            <i class="fas fa-box-archive"></i> Migrate tables to compendium
          </button>
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="hubFoldLegacyLoot"
                  title="Copy the legacy world &quot;Loot&quot; pack's items into sde-items (originals stay; pack locked as backup).">
            <i class="fas fa-boxes-packing"></i> Fold legacy Loot into Items
          </button>
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="mimportBackfill"
                  title="Upgrade existing imported NPCs to fresh-import fidelity (descriptions, icons, art, spells).">
            <i class="fas fa-arrow-up-from-bracket"></i> Backfill monsters
          </button>
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="mimportMigrateSuite"
                  title="Move world-side imported monster actors into the sde-actors compendium pack.">
            <i class="fas fa-box-archive"></i> Migrate monsters to suite
          </button>
        </div>
      </section>

    </div>
    {{else}}
    <p class="sde-hub-manage-loading"><i class="fas fa-circle-info"></i> Expand to load the census &amp; cleanup tools…</p>
    {{/if}}
  </details>

</div>
