  {{!-- ═══ Journal tab ═══ --}}
  <div class="sde-hub-tab-body sde-hub-monsters sde-hub-journal"{{#unless tabJournal}} hidden{{/unless}} id="sde-hub-journal">

    {{#if journalData}}

      <section class="sde-hub-monsters-census">
        <h3 class="sde-hub-monsters-section-title">
          <i class="fas fa-book"></i> Keyed Journals ({{journalData.crawlCount}})
        </h3>

        {{#if journalData.noCrawls}}
        <p class="sde-hub-monsters-empty">
          No keyed journals in sde-journal yet. Paste a hex key or numbered-location
          adventure on the Import tab and click <strong>Create journal</strong>.
        </p>
        {{else}}
        <table class="sde-hub-monsters-table">
          <thead>
            <tr>
              <th class="sde-hub-monsters-th-source">Crawl</th>
              <th title="Hex key or numbered locations">Mode</th>
              <th class="sde-hub-monsters-th-have" title="Keyed pages">Pages</th>
              <th class="sde-hub-monsters-th-have" title="@UUID links across pages">Links</th>
              <th title="Deployed into the world as a live journal">World</th>
              <th title="Scenes with pins bound to this crawl">Scenes</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {{#each journalData.crawls as |c|}}
            <tr class="sde-hub-monsters-row">
              <td class="sde-hub-monsters-source">
                {{c.name}}{{#if c.source}} <span class="sde-thub-src-n">{{c.source}}</span>{{/if}}
              </td>
              <td>{{c.keyMode}}</td>
              <td class="sde-hub-monsters-have">{{c.pageCount}}</td>
              <td class="sde-hub-monsters-have">{{c.linkCount}}</td>
              <td>
                {{#if c.deployed}}
                <span class="sde-thub-badge ok"><i class="fas fa-check"></i> Deployed</span>
                {{else}}
                <span class="sde-thub-badge miss"><i class="fas fa-circle-exclamation"></i> Not deployed</span>
                {{/if}}
              </td>
              <td>{{#if c.sceneCount}}{{c.sceneCount}} ({{c.pinCount}} pins){{else}}—{{/if}}</td>
              <td class="sde-hub-journal-actions">
                {{#unless c.deployed}}
                <button type="button" class="sde-hub-monsters-maint-btn" data-action="journalDeploy" data-uuid="{{c.uuid}}"
                        title="Create a live world journal from this crawl (pins open its pages).">
                  <i class="fas fa-cloud-arrow-up"></i> Deploy
                </button>
                {{/unless}}
                <button type="button" class="sde-hub-monsters-maint-btn" data-action="journalOpen" data-uuid="{{c.uuid}}"
                        title="Open this journal entry.">
                  <i class="fas fa-up-right-from-square"></i> Open
                </button>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
      </section>

      <section class="sde-hub-monsters-maintenance">
        <h3 class="sde-hub-monsters-section-title"><i class="fas fa-wrench"></i> Maintenance</h3>
        <div class="sde-hub-monsters-maintenance-row">
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="hubRelinkJournals"
                  title="Re-link keyed journal pages to imported monsters and items, then synchronize any deployed world copies.">
            <i class="fas fa-book-open"></i> Re-link journal pages
          </button>
          <button type="button" class="sde-hub-monsters-maint-btn" data-action="hubBuildScene"
                  title="Deploy a keyed journal into the world and build its calibrated map scene with pins.">
            <i class="fas fa-map-location-dot"></i> Build scene
          </button>
        </div>
      </section>

    {{else}}
    <div class="sde-hub-placeholder">
      <i class="fas fa-book sde-hub-placeholder-icon"></i>
      <p class="sde-hub-placeholder-title">Journal Dashboard</p>
      <p class="sde-hub-placeholder-note">Switch to this tab to load your keyed journals.</p>
    </div>
    {{/if}}

  </div>

  {{!-- ═══ Scenes tab ═══ --}}
  <div class="sde-hub-tab-body sde-hub-monsters sde-hub-scenes"{{#unless tabScenes}} hidden{{/unless}} id="sde-hub-scenes">

    {{#if scenesData}}

      <section class="sde-hub-monsters-census">
        <h3 class="sde-hub-monsters-section-title">
          <i class="fas fa-map"></i> Map Scenes ({{scenesData.sceneCount}})
          <span class="sde-thub-src-n" title="Scenes with an sde-scenes backup">{{scenesData.backedUp}} backed up</span>
        </h3>

        {{#if scenesData.noScenes}}
        <p class="sde-hub-monsters-empty">
          No keyed map scenes in this world. Use <strong>Build scene</strong> on the
          Journal tab to deploy a keyed journal as a pinned map.
        </p>
        {{else}}
        <table class="sde-hub-monsters-table">
          <thead>
            <tr>
              <th class="sde-hub-monsters-th-source">Scene</th>
              <th title="Grid type">Grid</th>
              <th class="sde-hub-monsters-th-have" title="Note pins on this scene">Pins</th>
              <th title="Pins whose bound journal page resolves">Resolved</th>
              <th title="An exact-id backup exists in sde-scenes">Backup</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {{#each scenesData.scenes as |s|}}
            <tr class="sde-hub-monsters-row">
              <td class="sde-hub-monsters-source">
                {{s.name}}{{#if s.active}} <span class="sde-thub-badge ok" title="Active scene"><i class="fas fa-eye"></i></span>{{/if}}{{#if s.source}} <span class="sde-thub-src-n">{{s.source}}</span>{{/if}}
              </td>
              <td>{{s.grid}}</td>
              <td class="sde-hub-monsters-have">{{s.pins}}</td>
              <td class="sde-hub-monsters-gap{{#unless s.allResolved}} has-gap{{/unless}}">
                {{#if s.resolvedPct}}{{s.resolved}}/{{s.bound}} ({{s.resolvedPct}}%){{else}}—{{/if}}
              </td>
              <td>
                {{#if s.backedUp}}
                <span class="sde-thub-badge ok"><i class="fas fa-check"></i> Yes</span>
                {{else}}
                <span class="sde-thub-badge miss"><i class="fas fa-circle-exclamation"></i> None</span>
                {{/if}}
              </td>
              <td class="sde-hub-journal-actions">
                <button type="button" class="sde-hub-monsters-maint-btn" data-action="sceneView" data-uuid="{{s.uuid}}"
                        title="View this scene on the canvas.">
                  <i class="fas fa-eye"></i> View
                </button>
                <button type="button" class="sde-hub-monsters-maint-btn" data-action="sceneBackup" data-uuid="{{s.uuid}}"
                        title="Create or refresh an exact-id backup of this scene in sde-scenes.">
                  <i class="fas fa-box-archive"></i> {{#if s.backedUp}}Re-backup{{else}}Backup{{/if}}
                </button>
                <button type="button" class="sde-hub-monsters-maint-btn" data-action="sceneOpen" data-uuid="{{s.uuid}}"
                        title="Open this scene's configuration.">
                  <i class="fas fa-up-right-from-square"></i> Open
                </button>
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
        {{/if}}
      </section>

    {{else}}
    <div class="sde-hub-placeholder">
      <i class="fas fa-map sde-hub-placeholder-icon"></i>
      <p class="sde-hub-placeholder-title">Scenes Dashboard</p>
      <p class="sde-hub-placeholder-note">Switch to this tab to load your map scenes.</p>
    </div>
    {{/if}}

  </div>

</div>
