<section class="sde-tam">

  <header class="sde-tam-head">
    <div class="sde-tam-blurb">
      Choose which installed art source skins each monster. The order below sets the
      default; click a thumbnail to override a single monster. <strong>Apply</strong> makes
      every future monster drag use your picks (nothing is copied — art is referenced from disk).
    </div>
    <div class="sde-tam-actions">
      <button type="button" data-action="apply" class="sde-tam-apply">
        <i class="fa-solid fa-wand-magic-sparkles"></i> Apply{{#if enabled}} (update){{/if}}
      </button>
      <button type="button" data-action="reskinPlaced" title="Fix monsters already placed on scenes / in the Actors tab">
        <i class="fa-solid fa-street-view"></i> Re-skin placed
      </button>
      <button type="button" data-action="resetAll" title="Clear all per-monster overrides">
        <i class="fa-solid fa-rotate-left"></i> Reset picks
      </button>
      {{#if enabled}}
      <button type="button" data-action="turnOff" title="Restore default art">
        <i class="fa-solid fa-power-off"></i> Turn off
      </button>
      {{/if}}
      <button type="button" data-action="refresh" title="Rescan installed art sources">
        <i class="fa-solid fa-arrows-rotate"></i>
      </button>
    </div>
  </header>

  <div class="sde-tam-sources">
    <div class="sde-tam-sources-title">Source priority <span class="sde-tam-dim">(highest wins where a monster has art in more than one)</span></div>
    {{#each sources}}
    <div class="sde-tam-source">
      <div class="sde-tam-rank">
        <button type="button" data-action="sourceUp" data-source="{{id}}" {{#if isFirst}}disabled{{/if}} title="Higher priority"><i class="fa-solid fa-caret-up"></i></button>
        <button type="button" data-action="sourceDown" data-source="{{id}}" {{#if isLast}}disabled{{/if}} title="Lower priority"><i class="fa-solid fa-caret-down"></i></button>
      </div>
      <div class="sde-tam-source-name">
        {{label}}
        <span class="sde-tam-dim">· {{count}} available{{#if kind}} · {{kind}}{{/if}}</span>
      </div>
      <div class="sde-tam-source-used" title="Monsters currently using this source">{{used}}</div>
    </div>
    {{/each}}
  </div>

  <div class="sde-tam-toolbar">
    <input type="text" name="filter" placeholder="Filter monsters…" value="{{filter}}" autocomplete="off">
    <label class="sde-tam-toggle">
      <input type="checkbox" name="conflicts" {{#if conflictsOnly}}checked{{/if}}> Only monsters with a choice
    </label>
    <span class="sde-tam-count">{{shown}} / {{total}}</span>
  </div>

  <div class="sde-tam-list">
    {{#each rows}}
    <div class="sde-tam-row {{#if isOverride}}is-override{{/if}}" data-name="{{name}}" data-multi="{{#if multi}}1{{/if}}">
      <div class="sde-tam-name">
        {{name}}
        {{#if isOverride}}<i class="fa-solid fa-thumbtack" title="Overridden — click to clear" data-action="clearRow" data-monster="{{id}}"></i>{{/if}}
      </div>
      <div class="sde-tam-opts">
        {{#each options}}
        <button type="button" class="sde-tam-opt {{#if chosen}}is-chosen{{/if}}" data-action="choose" data-monster="{{../id}}" data-source="{{source}}" title="{{label}}{{#if ring}} · ring{{/if}}">
          <img src="/{{thumb}}" loading="lazy" alt="{{label}}">
          {{#if chosen}}<i class="fa-solid fa-check sde-tam-check"></i>{{/if}}
        </button>
        {{/each}}
      </div>
    </div>
    {{/each}}
    {{#unless rows.length}}<div class="sde-tam-empty">No monsters match.</div>{{/unless}}
  </div>

</section>
